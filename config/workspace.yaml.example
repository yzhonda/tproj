# tproj multi-project workspace configuration
#
# Copy this file to:
#   ~/.config/tproj/workspace.yaml
#
# Example:
#   mkdir -p ~/.config/tproj
#   cp config/workspace.yaml.example ~/.config/tproj/workspace.yaml
#
# After editing this file, run:
#   tproj
#
# Check configured projects with:
#   tproj --check

# ===== Optional global launch args =====
#
# These apply to both workspace mode and single-project mode.
# They append to the built-in launcher command; they do not replace it.
#
# launch:
#   claude:
#     args:
#       - --model
#       - sonnet
#   codex:
#     args:
#       - -m
#       - gpt-5.3-codex
#
# ===== Optional tmux UI overrides =====
#
# These apply to tproj-created tmux windows only.
# Values are tmux style tokens (for example: colour51, colour248, default, terminal).
#
# tmux_ui:
#   pane_border:
#     active_fg: colour51
#     active_bold: true
#     inactive_fg: colour248
#     prev1_fg: colour211
#     prev2_fg: colour175
#   pane_title:
#     active_prefix: "▶ "
#     active_fg: colour255
#     active_bg: colour236
#     inactive_prefix: "  "
#     inactive_fg: colour255
#     inactive_bg: colour238
#     prev1_fg: colour211
#     prev1_bg: colour237
#     prev2_fg: colour175
#     prev2_bg: colour237
#   window_text:
#     active_fg: default
#     active_bg: terminal
#     inactive_fg: colour250
#     inactive_bg: terminal

# ===== Simple format (local projects only) =====
#
# A plain list of project paths.
# Every entry is treated as:
#   type: local
#   enabled: true
#
# projects:
#   - /Users/<username>/projects/claude/tproj
#   - /Users/<username>/projects/claude/statusline
#   - /Users/<username>/projects/claude/cc-status-bar
#
# Do not mix simple and detailed formats.

# ===== Optional GUI settings =====
#
# gui:
#   keep_alive: true    # default true:
#                       # tproj stop/kill does not close GUI
#                       # false closes GUI on stop/kill
#
#   # Optional fixed GUI app path (recommended for development)
#   # Accepts either:
#   #   /path/to/tproj.app
#   #   /path/to/tproj.app/Contents/MacOS/tproj
#   app_path: /Users/<username>/projects/claude/tproj/apps/tproj/dist/tproj.app
#
#   # Extra directories to add to the GUI app's PATH
#   # Builtin defaults (~/bin, /opt/homebrew/bin, /usr/local/bin) are always included
#   extra_paths:
#     - /opt/custom/bin
#     # - /another/path
#
#   # Commands checked at startup; missing ones show hints in the UI
#   # Builtin defaults: tmux (required), yq (optional)
#   dependencies:
#     - name: tmux
#       required: true
#       hint: brew install tmux
#     - name: yq
#       required: false
#       hint: brew install yq
#
#   # External bridge for inter-pane messaging (optional, used by tproj-msg)
#   bridge:
#     url: http://localhost:8765    # Bridge server URL
#     default_adapter: direct       # Default adapter

# ===== Detailed format (local + remote) =====

projects:
  # Local project (enabled at startup)
  - path: /Users/<username>/projects/claude/tproj
    alias: tproj

  # Local project (disabled at startup, can be added later)
  - path: /Users/<username>/projects/claude/statusline
    alias: sl
    enabled: false   # GUI Stop remembers the current manual-Start set by rewriting enabled

  # Remote project over SSH
  - path: /Users/<username>/projects/my-api-server
    type: remote
    host: remote-host
    alias: api

# ===== Field reference =====
#
# path    : string (required)
#           Project path. Use absolute paths for local projects.
#           Remote projects use paths on the remote host (supports ~).
#
# type    : local | remote (optional, default: local)
#
# host    : string (required when type=remote)
#           SSH host name from ~/.ssh/config.
#
# alias   : string (optional, default: basename(path))
#           Used by: tproj --add <alias>
#
# enabled : bool (optional, default: true)
#           false means excluded at startup but available via --add.
#           When a workspace session is stopped from the GUI, the current running set
#           is written back here and becomes the next manual Start set.

# ===== Recommended limits =====
#
# - Keep projects around 5 or fewer to avoid narrow columns.
# - Remote mode (-r) is not available together with multi-project mode.
# - Remote projects must have claude, codex, and yazi installed.
