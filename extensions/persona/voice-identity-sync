#!/bin/bash
# voice-identity-sync - patch .cc-status-bar.voice.json identity fields only.
# Leaves events/defaults/tool_readings untouched. Idempotent. Dictionary-driven.
#
# Usage:
#   voice-identity-sync <project_path>
#   voice-identity-sync <project_path> --alias <name>
#   voice-identity-sync <project_path> --force
#
# Exits 0 if voice.json missing (defer to project-bootstrap), no diff, or success.

set -eo pipefail

PROJECT_PATH=""
EXPLICIT_ALIAS=""
FORCE=0
QUIET=0
while [ $# -gt 0 ]; do
  case "$1" in
    --alias) EXPLICIT_ALIAS="$2"; shift 2 ;;
    --force) FORCE=1; shift ;;
    --quiet|-q) QUIET=1; shift ;;
    --help|-h) sed -n '1,12p' "$0"; exit 0 ;;
    --) shift; break ;;
    -*) echo "voice-identity-sync: unknown flag: $1" >&2; exit 2 ;;
    *)
      if [ -z "$PROJECT_PATH" ]; then
        PROJECT_PATH="$1"
      else
        echo "voice-identity-sync: unexpected arg: $1" >&2; exit 2
      fi
      shift ;;
  esac
done

[ -n "$PROJECT_PATH" ] || { echo "voice-identity-sync: missing project_path" >&2; exit 2; }
VOICE_FILE="$PROJECT_PATH/.cc-status-bar.voice.json"
[ -f "$VOICE_FILE" ] || exit 0
command -v jq >/dev/null || { echo "voice-identity-sync: jq required" >&2; exit 2; }

log() { [ "$QUIET" = "1" ] || printf '%s\n' "$*" >&2; }

# --- Dictionary functions (mirrors project-bootstrap voice_*_reading family) ---
voice_letter_reading() {
  case "$1" in
    a) echo "エー" ;; b) echo "ビー" ;; c) echo "シー" ;; d) echo "ディー" ;;
    e) echo "イー" ;; f) echo "エフ" ;; g) echo "ジー" ;; h) echo "エイチ" ;;
    i) echo "アイ" ;; j) echo "ジェー" ;; k) echo "ケー" ;; l) echo "エル" ;;
    m) echo "エム" ;; n) echo "エヌ" ;; o) echo "オー" ;; p) echo "ピー" ;;
    q) echo "キュー" ;; r) echo "アール" ;; s) echo "エス" ;; t) echo "ティー" ;;
    u) echo "ユー" ;; v) echo "ブイ" ;; w) echo "ダブリュー" ;; x) echo "エックス" ;;
    y) echo "ワイ" ;; z) echo "ズィー" ;; *) echo "$1" ;;
  esac
}

