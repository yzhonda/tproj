voice_alpha_token_reading() {
  local token="$1" lowered reading="" ch
  lowered="$(printf '%s' "$token" | tr '[:upper:]' '[:lower:]')"
  if reading="$(voice_known_token_reading "$lowered" 2>/dev/null)"; then
    printf '%s\n' "$reading"; return 0
  fi
  if [[ "$lowered" =~ ^[a-z]+$ ]]; then
    while [ -n "$lowered" ]; do
      ch="${lowered:0:1}"
      lowered="${lowered:1}"
      reading="${reading}$(voice_letter_reading "$ch")"
    done
    printf '%s\n' "$reading"; return 0
  fi
  return 1
}

voice_generic_project_reading() {
  local project_name="$1" sanitized token reading out=""
  sanitized="$(printf '%s\n' "$project_name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/ /g')"
  for token in $sanitized; do
    if reading="$(voice_alpha_token_reading "$token" 2>/dev/null)"; then
      :
    else
      reading="$token"
    fi
    out="${out}${reading}"
  done
  printf '%s\n' "$out"
}

voice_project_reading() {
  local project_name="$1"
  case "$project_name" in
    "ana") echo "アナ" ;;
    "oc-general") echo "オーシージェネラル" ;;
    "tproj") echo "ティープロジ" ;;
    "aillio") echo "アイリオ" ;;
