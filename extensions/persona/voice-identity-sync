    "release") echo "リリース" ;;
    "openclaw") echo "オープンクロー" ;;
    *) voice_generic_project_reading "$project_name" ;;
  esac
}

voice_project_spoken() { voice_project_reading "$1"; }

voice_project_alias_spoken() {
  local alias_name="$1"
  [ -z "$alias_name" ] && { echo ""; return; }
  voice_generic_project_reading "$alias_name"
}

resolve_alias_from_workspace() {
  local project_path="$1"
  local ws_file="$HOME/.config/tproj/workspace.yaml"
  [ -f "$ws_file" ] || { echo ""; return; }
  awk -v target="$project_path" '
    /^  - path:/ { p=$0; sub(/.*path: *\047?/,"",p); sub(/\047? *$/,"",p) }
    /alias:/ { a=$0; sub(/.*alias: *\047?/,"",a); sub(/\047? *$/,"",a);
               if (p==target) { print a; exit } }
  ' "$ws_file"
}

# Garbage detection: a value is "garbage" if it leaks raw ASCII letters
# (e.g., alias "2026nc" passing through unmapped) OR has 4+ consecutive
# letter-spell tokens.
LETTER_PATTERN='(エー|ビー|シー|ディー|イー|エフ|ジー|エイチ|アイ|ジェー|ケー|エル|エム|エヌ|オー|ピー|キュー|アール|エス|ティー|ユー|ブイ|ダブリュー|エックス|ワイ|ズィー){4,}'
is_letter_spell_garbage() {
  local s="$1"
  [ -z "$s" ] && return 1
  if [[ "$s" =~ [a-zA-Z] ]]; then
    return 0
  fi
  printf '%s' "$s" | grep -qE "$LETTER_PATTERN"
}

# Returns 0 (true) if alias would produce pure letter-spell katakana
# (no real-word tokens). Used to skip alias_spoken auto-set for short
# acronym aliases like "mp", "bb", "nlk".
is_alias_letter_spell() {
  local alias_name="$1" sanitized token reading lowered ch expected has_real=0
  sanitized="$(printf '%s\n' "$alias_name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/ /g')"
  for token in $sanitized; do
    [ -z "$token" ] && continue
    if [[ ! "$token" =~ ^[a-z]+$ ]]; then
      has_real=1
      continue
    fi
    reading="$(voice_alpha_token_reading "$token" 2>/dev/null)" || continue
    expected=""
    lowered="$token"
    while [ -n "$lowered" ]; do
      ch="${lowered:0:1}"
      lowered="${lowered:1}"
      expected="${expected}$(voice_letter_reading "$ch")"
    done
    if [ "$reading" != "$expected" ]; then
      has_real=1
    fi
  done
  [ "$has_real" = "0" ]
}

# --- Compute expected values ---
PROJECT_NAME="$(basename "$PROJECT_PATH")"
EXPECTED_PROJECT_READING="$(voice_project_reading "$PROJECT_NAME")"
EXPECTED_PROJECT_SPOKEN="$(voice_project_spoken "$PROJECT_NAME")"
ALIAS_NAME="${EXPLICIT_ALIAS:-$(resolve_alias_from_workspace "$PROJECT_PATH")}"
EXPECTED_ALIAS_SPOKEN=""
ALIAS_IS_LETTER_SPELL=0
if [ -n "$ALIAS_NAME" ] && [ "$ALIAS_NAME" != "$PROJECT_NAME" ]; then
  if is_alias_letter_spell "$ALIAS_NAME"; then
    ALIAS_IS_LETTER_SPELL=1
  else
    EXPECTED_ALIAS_SPOKEN="$(voice_project_alias_spoken "$ALIAS_NAME")"
  fi
fi

# --- Read current values ---
CURRENT_PROJECT_NAME="$(jq -r '.identity.project_name // ""' "$VOICE_FILE")"
CURRENT_PROJECT_READING="$(jq -r '.identity.project_reading // ""' "$VOICE_FILE")"
CURRENT_PROJECT_SPOKEN="$(jq -r '.identity.project_spoken // ""' "$VOICE_FILE")"
CURRENT_ALIAS_SPOKEN="$(jq -r '.identity.alias_spoken // ""' "$VOICE_FILE")"

# --- Decide what to update ---
should_update() {
  local current="$1" expected="$2"
  [ -z "$expected" ] && return 1
  [ "$current" = "$expected" ] && return 1
  # Regression guard: never overwrite a clean value with letter-spell garbage.
  if is_letter_spell_garbage "$expected"; then
    if [ -n "$current" ] && ! is_letter_spell_garbage "$current"; then
      return 1
    fi
  fi
  if [ "$FORCE" = "1" ]; then return 0; fi
  [ -z "$current" ] && return 0
  is_letter_spell_garbage "$current" && return 0
  return 1
}

NEW_PROJECT_NAME="$CURRENT_PROJECT_NAME"
NEW_PROJECT_READING="$CURRENT_PROJECT_READING"
NEW_PROJECT_SPOKEN="$CURRENT_PROJECT_SPOKEN"
NEW_ALIAS_SPOKEN="$CURRENT_ALIAS_SPOKEN"

# project_name should always match basename
if [ "$CURRENT_PROJECT_NAME" != "$PROJECT_NAME" ]; then
  NEW_PROJECT_NAME="$PROJECT_NAME"
fi

if should_update "$CURRENT_PROJECT_READING" "$EXPECTED_PROJECT_READING"; then
  NEW_PROJECT_READING="$EXPECTED_PROJECT_READING"
fi
if should_update "$CURRENT_PROJECT_SPOKEN" "$EXPECTED_PROJECT_SPOKEN"; then
  NEW_PROJECT_SPOKEN="$EXPECTED_PROJECT_SPOKEN"
fi

# alias_spoken: clear when alias matches project_name OR is pure letter-spell;
# otherwise apply standard rule. Pure letter-spell aliases (mp, bb, nlk) would
# override project_spoken with abbreviated readings, which is undesirable.
if [ -z "$ALIAS_NAME" ] || [ "$ALIAS_NAME" = "$PROJECT_NAME" ] || [ "$ALIAS_IS_LETTER_SPELL" = "1" ]; then
  if [ "$FORCE" = "1" ] && [ -n "$CURRENT_ALIAS_SPOKEN" ]; then
    NEW_ALIAS_SPOKEN=""
  fi
elif should_update "$CURRENT_ALIAS_SPOKEN" "$EXPECTED_ALIAS_SPOKEN"; then
  NEW_ALIAS_SPOKEN="$EXPECTED_ALIAS_SPOKEN"
fi

# Cleanup: alias_spoken should never contain ASCII letters (raw alias leak
# from incomplete dictionary coverage, e.g., "2026nc"). Clear if detected.
if [ -n "$NEW_ALIAS_SPOKEN" ] && [[ "$NEW_ALIAS_SPOKEN" =~ [a-zA-Z] ]]; then
  NEW_ALIAS_SPOKEN=""
fi

# No-op detection
if [ "$NEW_PROJECT_NAME" = "$CURRENT_PROJECT_NAME" ] \
   && [ "$NEW_PROJECT_READING" = "$CURRENT_PROJECT_READING" ] \
   && [ "$NEW_PROJECT_SPOKEN" = "$CURRENT_PROJECT_SPOKEN" ] \
   && [ "$NEW_ALIAS_SPOKEN" = "$CURRENT_ALIAS_SPOKEN" ]; then
  exit 0
fi

# Atomic patch via jq
TMP="$(mktemp "${VOICE_FILE}.tmp.XXXXXX")"
trap 'rm -f "$TMP"' EXIT
jq \
  --arg project_name "$NEW_PROJECT_NAME" \
  --arg project_reading "$NEW_PROJECT_READING" \
  --arg project_spoken "$NEW_PROJECT_SPOKEN" \
  --arg alias_spoken "$NEW_ALIAS_SPOKEN" \
  '.identity.project_name = $project_name
   | .identity.project_reading = $project_reading
   | .identity.project_spoken = $project_spoken
   | .identity.alias_spoken = $alias_spoken' \
  "$VOICE_FILE" > "$TMP"
jq empty "$TMP" >/dev/null
mv "$TMP" "$VOICE_FILE"
trap - EXIT

log "voice-identity-sync: patched $VOICE_FILE"
log "  project_name:    ${CURRENT_PROJECT_NAME} -> ${NEW_PROJECT_NAME}"
log "  project_reading: ${CURRENT_PROJECT_READING} -> ${NEW_PROJECT_READING}"
log "  project_spoken:  ${CURRENT_PROJECT_SPOKEN} -> ${NEW_PROJECT_SPOKEN}"
log "  alias_spoken:    ${CURRENT_ALIAS_SPOKEN} -> ${NEW_ALIAS_SPOKEN}"
