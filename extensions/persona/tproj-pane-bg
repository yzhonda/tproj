session_env_value() {
  local session="$1"
  local key="$2"
  local line=""

  line="$(tmux show-environment -t "$session" 2>/dev/null | awk -F= -v key="$key" '$1 == key {sub($1 "=",""); print; exit}')"
  printf '%s' "$line"
}

prime_session_api_env() {
  local session="$1"

  if [[ -n "${GEMINI_API_KEY:-}" ]]; then
    tmux set-environment -t "$session" GEMINI_API_KEY "$GEMINI_API_KEY" >/dev/null 2>&1 || true
  fi
  if [[ -n "${GOOGLE_API_KEY:-}" ]]; then
    tmux set-environment -t "$session" GOOGLE_API_KEY "$GOOGLE_API_KEY" >/dev/null 2>&1 || true
  fi
  if [[ -n "${GOOGLE_CLOUD_PROJECT:-}" ]]; then
    tmux set-environment -t "$session" GOOGLE_CLOUD_PROJECT "$GOOGLE_CLOUD_PROJECT" >/dev/null 2>&1 || true
  fi
  if [[ -n "${GOOGLE_CLOUD_LOCATION:-}" ]]; then
    tmux set-environment -t "$session" GOOGLE_CLOUD_LOCATION "$GOOGLE_CLOUD_LOCATION" >/dev/null 2>&1 || true
  fi
}

hydrate_api_env_from_session() {
  local session="$1"
  local session_gemini=""
  local session_google=""
  local session_project=""
  local session_location=""

  if [[ -z "${GEMINI_API_KEY:-}" ]]; then
    session_gemini="$(session_env_value "$session" GEMINI_API_KEY)"
    if [[ -n "$session_gemini" ]]; then
      export GEMINI_API_KEY="$session_gemini"
    fi
  fi

  if [[ -z "${GOOGLE_API_KEY:-}" ]]; then
    session_google="$(session_env_value "$session" GOOGLE_API_KEY)"
    if [[ -n "$session_google" ]]; then
      export GOOGLE_API_KEY="$session_google"
    fi
  fi

  if [[ -z "${GOOGLE_CLOUD_PROJECT:-}" ]]; then
    session_project="$(session_env_value "$session" GOOGLE_CLOUD_PROJECT)"
    if [[ -n "$session_project" ]]; then
      export GOOGLE_CLOUD_PROJECT="$session_project"
    fi
  fi

  if [[ -z "${GOOGLE_CLOUD_LOCATION:-}" ]]; then
    session_location="$(session_env_value "$session" GOOGLE_CLOUD_LOCATION)"
    if [[ -n "$session_location" ]]; then
      export GOOGLE_CLOUD_LOCATION="$session_location"
    fi
  fi
}

