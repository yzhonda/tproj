parse_persona_output() {
  local persona_output="$1"
  local role="$2"
  local line=""
  case "$role" in
    cc) line="$(printf '%s\n' "$persona_output" | awk '/^CC  Persona: /{print; exit}')" ;;
    cdx) line="$(printf '%s\n' "$persona_output" | awk '/^Cdx Persona: /{print; exit}')" ;;
    *) die "unsupported role: $role" ;;
  esac
  [[ -n "$line" ]] || die "could not parse persona output for role ${role}"
  printf '%s' "$line"
}

apply_prof_override() {
  local persona_line="$1"
  local prof_override="$2"
  local trimmed_prof=""

  trimmed_prof="$(trim "$prof_override")"
  [[ -n "$trimmed_prof" ]] || {
    printf '%s' "$persona_line"
    return 0
  }

  if [[ "$persona_line" == *" / prof:"* ]]; then
    printf '%s / prof:%s' "${persona_line%% / prof:*}" "$trimmed_prof"
  else
    printf '%s / prof:%s' "$persona_line" "$trimmed_prof"
  fi
}

