  swift - "$image_path" "$TARGET_WIDTH" "$TARGET_HEIGHT" "$FACE_CROP_TARGET_FACE_HEIGHT_RATIO" "$FACE_CROP_MAX_ZOOM" "$FACE_CROP_POLICY" <<'SWIFT'
import Foundation
import Vision
import CoreGraphics
import ImageIO

let args = CommandLine.arguments
guard args.count >= 7 else {
    fputs("missing arguments\n", stderr)
    exit(2)
}

let imagePath = args[1]
let targetWidth = Double(args[2]) ?? 1024
let targetHeight = Double(args[3]) ?? 1536
let targetFaceRatio = Double(args[4]) ?? 0.24
let preferredMaxZoom = Double(args[5]) ?? 1.75
let policy = args[6]

func regionPoints(_ region: VNFaceLandmarkRegion2D?, in faceBox: CGRect, sourceWidth: Double, sourceHeight: Double) -> [(Double, Double)] {
    guard let region else { return [] }
    return (0..<region.pointCount).map { index in
        let point = region.normalizedPoints[index]
        let x = (faceBox.origin.x + CGFloat(point.x) * faceBox.width) * CGFloat(sourceWidth)
        let yTop = (1.0 - (faceBox.origin.y + CGFloat(point.y) * faceBox.height)) * CGFloat(sourceHeight)
        return (Double(x), Double(yTop))
    }
}

let url = URL(fileURLWithPath: imagePath) as CFURL
guard let source = CGImageSourceCreateWithURL(url, nil),
      let image = CGImageSourceCreateImageAtIndex(source, 0, nil) else {
    fputs("could not load image\n", stderr)
    exit(3)
}

let request = VNDetectFaceLandmarksRequest()
let handler = VNImageRequestHandler(cgImage: image, options: [:])
do {
    try handler.perform([request])
} catch {
    fputs("vision failed: \(error)\n", stderr)
    exit(4)
}

let observations = (request.results ?? []).compactMap { $0 as? VNFaceObservation }
guard let face = observations.max(by: { ($0.boundingBox.width * $0.boundingBox.height) < ($1.boundingBox.width * $1.boundingBox.height) }) else {
    let payload: [String: Any] = [
        "policy": policy,
        "detector": "macos-vision",
        "fallback_used": true,
        "reason": "no_face_detected"
    ]
    let data = try JSONSerialization.data(withJSONObject: payload, options: [])
    FileHandle.standardOutput.write(data)
    exit(0)
}

let sourceWidth = Double(image.width)
let sourceHeight = Double(image.height)
let targetAspect = targetWidth / targetHeight
let bbox = face.boundingBox

let faceWidth = bbox.width * sourceWidth
let faceHeight = bbox.height * sourceHeight
let faceBBoxTopYNorm = 1.0 - (bbox.origin.y + bbox.height)
let faceRollRadians = face.roll?.doubleValue
let faceYawRadians = face.yaw?.doubleValue
let facePitchRadians = face.pitch?.doubleValue
let sidewaysDetected = (faceRollRadians.map { abs($0) >= 0.7853981633974483 } ?? false)

let landmarkPoints = (
    regionPoints(face.landmarks?.faceContour, in: bbox, sourceWidth: sourceWidth, sourceHeight: sourceHeight) +
    regionPoints(face.landmarks?.leftEye, in: bbox, sourceWidth: sourceWidth, sourceHeight: sourceHeight) +
    regionPoints(face.landmarks?.rightEye, in: bbox, sourceWidth: sourceWidth, sourceHeight: sourceHeight) +
    regionPoints(face.landmarks?.nose, in: bbox, sourceWidth: sourceWidth, sourceHeight: sourceHeight) +
    regionPoints(face.landmarks?.outerLips, in: bbox, sourceWidth: sourceWidth, sourceHeight: sourceHeight) +
    regionPoints(face.landmarks?.innerLips, in: bbox, sourceWidth: sourceWidth, sourceHeight: sourceHeight)
)

let faceCenterX: Double
let faceCenterYTop: Double
let faceCenterSource: String

if !landmarkPoints.isEmpty {
    let minX = landmarkPoints.map(\.0).min() ?? ((bbox.origin.x + bbox.width / 2.0) * sourceWidth)
    let maxX = landmarkPoints.map(\.0).max() ?? minX
    let minY = landmarkPoints.map(\.1).min() ?? ((1.0 - (bbox.origin.y + bbox.height / 2.0)) * sourceHeight)
    let maxY = landmarkPoints.map(\.1).max() ?? minY
    faceCenterX = (minX + maxX) / 2.0
    faceCenterYTop = (minY + maxY) / 2.0
    faceCenterSource = "landmarks"
} else {
    faceCenterX = (bbox.origin.x + bbox.width / 2.0) * sourceWidth
    faceCenterYTop = (1.0 - (bbox.origin.y + bbox.height / 2.0)) * sourceHeight
    faceCenterSource = "bbox"
}

let baseCropWidth: Double
let baseCropHeight: Double
if sourceWidth / sourceHeight > targetAspect {
    baseCropHeight = sourceHeight
    baseCropWidth = sourceHeight * targetAspect
} else {
    baseCropWidth = sourceWidth
    baseCropHeight = sourceWidth / targetAspect
}

let allowedHeightFromY = max(1.0, 2.0 * min(faceCenterYTop, sourceHeight - faceCenterYTop))
let allowedHeightFromX = max(1.0, 2.0 * min(faceCenterX, sourceWidth - faceCenterX) / targetAspect)
let centeredHeightLimit = max(1.0, min(baseCropHeight, allowedHeightFromY, allowedHeightFromX))
let minPreferredCropHeight = max(1.0, baseCropHeight / preferredMaxZoom)
let idealCropHeight = max(1.0, faceHeight / targetFaceRatio)

var cropHeight = min(max(idealCropHeight, minPreferredCropHeight), baseCropHeight)
if cropHeight > centeredHeightLimit {
    cropHeight = centeredHeightLimit
}
cropHeight = max(1.0, cropHeight)

var cropWidth = cropHeight * targetAspect
var cropX = faceCenterX - cropWidth / 2.0
var cropY = faceCenterYTop - cropHeight / 2.0

cropX = min(max(0.0, cropX), max(0.0, sourceWidth - cropWidth))
cropY = min(max(0.0, cropY), max(0.0, sourceHeight - cropHeight))

var cropWidthInt = max(1, Int(cropWidth.rounded()))
var cropHeightInt = max(1, Int(cropHeight.rounded()))
cropWidthInt = min(cropWidthInt, Int(sourceWidth))
cropHeightInt = min(cropHeightInt, Int(sourceHeight))

if Double(cropWidthInt) / Double(cropHeightInt) > targetAspect {
    cropWidthInt = max(1, Int((Double(cropHeightInt) * targetAspect).rounded()))
} else {
    cropHeightInt = max(1, Int((Double(cropWidthInt) / targetAspect).rounded()))
}

let cropXInt = max(0, min(Int((faceCenterX - Double(cropWidthInt) / 2.0).rounded()), Int(sourceWidth) - cropWidthInt))
let cropYInt = max(0, min(Int((faceCenterYTop - Double(cropHeightInt) / 2.0).rounded()), Int(sourceHeight) - cropHeightInt))

let finalFaceCenterNormX = (faceCenterX - Double(cropXInt)) / Double(cropWidthInt)
let finalFaceCenterNormY = (faceCenterYTop - Double(cropYInt)) / Double(cropHeightInt)
let zoomFactor = baseCropHeight / Double(cropHeightInt)

let payload: [String: Any] = [
    "policy": policy,
    "detector": "macos-vision",
    "fallback_used": false,
    "face_center_source": faceCenterSource,
    "coordinate_space": "top-left-normalized",
    "source_size_px": [
        "width": Int(sourceWidth),
        "height": Int(sourceHeight),
    ],
    "face_bbox_norm": [
        "x": bbox.origin.x,
        "y": faceBBoxTopYNorm,
        "width": bbox.width,
        "height": bbox.height,
    ],
    "face_center_norm": [
        "x": faceCenterX / sourceWidth,
        "y": faceCenterYTop / sourceHeight,
    ],
    "crop_rect_px": [
        "x": cropXInt,
        "y": cropYInt,
        "width": cropWidthInt,
        "height": cropHeightInt,
    ],
    "output_face_center_norm": [
        "x": finalFaceCenterNormX,
        "y": finalFaceCenterNormY,
    ],
    "target_face_height_ratio": targetFaceRatio,
    "detected_face_height_ratio": faceHeight / sourceHeight,
    "output_face_height_ratio": faceHeight / Double(cropHeightInt),
    "zoom_factor": zoomFactor,
    "preferred_max_zoom": preferredMaxZoom,
    "preferred_zoom_exceeded": zoomFactor > preferredMaxZoom + 0.001,
    "face_roll_radians": faceRollRadians as Any,
    "face_yaw_radians": faceYawRadians as Any,
    "face_pitch_radians": facePitchRadians as Any,
    "sideways_detected": sidewaysDetected,
]

let data = try JSONSerialization.data(withJSONObject: payload, options: [])
FileHandle.standardOutput.write(data)
SWIFT
}

write_image_from_response() {
  local response_file="$1"
  local image_path="$2"
  local tmp_dir="$3"
  local encoded=""
  local mime_type=""
  local raw_path="${tmp_dir}/raw-image.bin"
  local decoded_path="${tmp_dir}/decoded-image.png"
  local current_face_crop_json=""
  local refined_output_path="${tmp_dir}/refined-image.png"
  local applied_passes=0
  local needs_refine=0

  LAST_FACE_CROP_JSON='null'
  encoded="$(extract_first_nonempty_json_string "$response_file")"
  [[ -n "$encoded" ]] || return 1
  mime_type="$(extract_first_mime_type "$response_file")"

  decode_base64_to_file "$encoded" "$raw_path"

  case "$mime_type" in
    image/png)
      mv "$raw_path" "$decoded_path"
      ;;
    *)
      if command -v magick >/dev/null 2>&1; then
        magick "$raw_path" PNG32:"$decoded_path"
      else
        mv "$raw_path" "$decoded_path"
      fi
      ;;
  esac

  if ! command -v magick >/dev/null 2>&1; then
    set_face_crop_fallback_json "magick_unavailable" "none"
    mv "$decoded_path" "$image_path"
    return 0
  fi

  write_center_cropped_image "$decoded_path" "$image_path"

  if ! command -v swift >/dev/null 2>&1; then
    set_face_crop_fallback_json "swift_unavailable" "none"
    return 0
  fi

  if ! current_face_crop_json="$(vision_face_crop_json "$image_path" 2>/dev/null)" || [[ -z "$current_face_crop_json" ]]; then
    set_face_crop_fallback_json "vision_detection_failed"
    return 1
  fi

  if [[ "$(jq -r 'if has("fallback_used") then .fallback_used else true end' <<<"$current_face_crop_json")" == "true" ]]; then
    LAST_FACE_CROP_JSON="$(jq -cn --argjson final "$current_face_crop_json" --argjson pass_count "$applied_passes" '
      $final + { pass_count: $pass_count }')"
    return 1
  fi

  if face_crop_is_sideways "$current_face_crop_json"; then
    LAST_FACE_CROP_JSON="$(jq -cn --argjson final "$current_face_crop_json" --argjson pass_count "$applied_passes" '
      $final + { fallback_used: true, reason: "sideways_face_roll", pass_count: $pass_count }')"
    return 1
  fi

  apply_face_crop_from_json "$image_path" "$refined_output_path" "$current_face_crop_json"
  mv "$refined_output_path" "$image_path"
  applied_passes=1

  if ! current_face_crop_json="$(vision_face_crop_json "$image_path" 2>/dev/null)" || [[ -z "$current_face_crop_json" ]]; then
    set_face_crop_fallback_json "vision_detection_failed_after_refine"
    return 0
  fi

  if [[ "$(jq -r 'if has("fallback_used") then .fallback_used else true end' <<<"$current_face_crop_json")" == "true" ]]; then
    LAST_FACE_CROP_JSON="$(jq -cn --argjson final "$current_face_crop_json" --argjson pass_count "$applied_passes" '
      $final + { pass_count: $pass_count }')"
    return 0
  fi

  if face_crop_is_sideways "$current_face_crop_json"; then
    LAST_FACE_CROP_JSON="$(jq -cn --argjson final "$current_face_crop_json" --argjson pass_count "$applied_passes" '
      $final + { fallback_used: true, reason: "sideways_face_roll_after_refine", pass_count: $pass_count }')"
    return 1
  fi

  needs_refine=0
  if face_crop_needs_refine "$current_face_crop_json"; then
    needs_refine=1
  fi

  if (( needs_refine != 0 )); then
    apply_face_crop_from_json "$image_path" "$refined_output_path" "$current_face_crop_json"
    mv "$refined_output_path" "$image_path"
    applied_passes=2
  fi

  if current_face_crop_json="$(vision_face_crop_json "$image_path" 2>/dev/null)" && [[ -n "$current_face_crop_json" ]]; then
    if [[ "$(jq -r 'if has("fallback_used") then .fallback_used else true end' <<<"$current_face_crop_json")" != "true" ]] && face_crop_is_sideways "$current_face_crop_json"; then
      LAST_FACE_CROP_JSON="$(jq -cn --argjson final "$current_face_crop_json" --argjson pass_count "$applied_passes" '
        $final + { fallback_used: true, reason: "sideways_face_roll_after_final_refine", pass_count: $pass_count }')"
      return 1
    fi
    LAST_FACE_CROP_JSON="$(jq -cn --argjson final "$current_face_crop_json" --argjson pass_count "$applied_passes" '
      $final + { pass_count: $pass_count }')"
  else
    set_face_crop_fallback_json "vision_detection_failed_after_refine"
  fi
}

generate_style_image() {
  local prompt="$1"
  local negative_prompt="$2"
  local response_file="$3"
  local api_key_value="$4"
  local image_path="$5"
  local tmp_dir="$6"
  local model_name="$7"
  local vertex_project="$8"
  local vertex_location="$9"
  local error_file="${tmp_dir}/request-error.json"
  local attempt=1

  LAST_GENERATION_ERROR_JSON='null'
  while (( attempt <= MAX_GENERATION_ATTEMPTS )); do
    : > "$response_file"
    rm -f "$error_file"
    if ! request_imagen "$prompt" "$negative_prompt" "$response_file" "$api_key_value" "$model_name" "$vertex_project" "$vertex_location" "$error_file"; then
      load_generation_error_json "$error_file"
      attempt=$((attempt + 1))
      continue
    fi
    if ! write_image_from_response "$response_file" "$image_path" "$tmp_dir"; then
      LAST_GENERATION_ERROR_JSON="$(jq -cn '{kind:"postprocess_failed", message:"write_image_from_response failed"}')"
      attempt=$((attempt + 1))
      continue
    fi
    LAST_GENERATION_ERROR_JSON='null'
    return 0
  done

  return 1
}

write_sidecar() {
  local meta_path="$1"
  local project="$2"
  local role="$3"
  local style_mode="$4"
  local prompt="$5"
  local negative_prompt="$6"
  local persona_line="$7"
  local image_path="$8"
  local response_file="$9"
  local gender_desc="${10}"
  local age_desc="${11}"
  local model_name="${12}"
  local prompt_version="${13}"
  local prompt_schema="${14}"
  local selection_reason="${15}"
  local prompt_hash=""
  local meta_tmp="${meta_path}.tmp"
  local style_preference=""

  prompt_hash="$(build_prompt_hash "$prompt" "$negative_prompt" "$persona_line" "$style_mode" "$model_name" "$prompt_version" "$prompt_schema")"
  style_preference="$(style_reference_for_mode "$style_mode")"

  jq -n \
    --arg project "$project" \
    --arg role "$role" \
    --arg model "$model_name" \
    --arg prompt_version "$prompt_version" \
    --arg prompt_schema "$prompt_schema" \
    --arg persona_source_version "$PERSONA_SOURCE_VERSION" \
    --arg generation_tier "$(generation_tier_for_model "$model_name")" \
    --arg selection_reason "$selection_reason" \
    --arg style_mode "$style_mode" \
    --arg style_preference "$style_preference" \
    --arg aspect_ratio "$ASPECT_RATIO" \
    --arg generated_at "$(now_utc)" \
    --arg image_path "$image_path" \
    --arg persona_line "$persona_line" \
    --arg mbti "$PERSONA_MBTI" \
    --arg gender_raw "$PERSONA_GENDER_RAW" \
    --arg gender "$gender_desc" \
    --arg age_raw "$PERSONA_AGE_RAW" \
    --arg age "$age_desc" \
    --arg era "$PERSONA_ERA" \
    --arg era_hint "$PERSONA_ERA_HINT" \
    --arg tone "$PERSONA_TONE" \
    --arg tone_hint "$PERSONA_TONE_HINT" \
    --arg chi_rel "$PERSONA_CHI_REL" \
    --arg chi_hint "$PERSONA_CHI_HINT" \
    --arg master_rel "$PERSONA_MASTER_REL" \
    --arg master_hint "$PERSONA_MASTER_HINT" \
    --arg callname "$PERSONA_CALLNAME" \
    --arg chara "$PERSONA_CHARA" \
    --arg chara_hint "$PERSONA_CHARA_HINT" \
    --arg prof "$PERSONA_PROF" \
    --arg effective_gender "$PERSONA_GENDER_RAW" \
    --arg effective_visual_age "$PERSONA_VISUAL_AGE" \
    --arg effective_era "$PERSONA_ERA" \
    --arg expression_mode "$PERSONA_EXPRESSION_MODE" \
    --arg pose_mode "$PERSONA_POSE_MODE" \
    --arg prop_mode "$PERSONA_PROP_MODE" \
    --arg prompt "$prompt" \
    --arg negative_prompt "$negative_prompt" \
    --arg prompt_hash "$prompt_hash" \
    --arg endpoint "google-genai://models/${model_name}" \
    --argjson face_crop "$LAST_FACE_CROP_JSON" \
    --slurpfile response_json "$response_file" \
    '{
      version: 1,
      project: $project,
      role: $role,
      model: $model,
      prompt_version: $prompt_version,
      prompt_schema: $prompt_schema,
      persona_source_version: $persona_source_version,
      generation_tier: $generation_tier,
      selection_reason: $selection_reason,
      style_mode: $style_mode,
      style_preference: $style_preference,
      aspect_ratio: $aspect_ratio,
      generated_at: $generated_at,
      image_path: $image_path,
      persona_line: $persona_line,
      persona: {
        mbti: $mbti,
        gender_raw: $gender_raw,
        gender: $gender,
        age_raw: $age_raw,
        age: $age,
        era: $era,
        era_hint: $era_hint,
        tone: $tone,
        tone_hint: $tone_hint,
        chi_rel: $chi_rel,
        chi_hint: $chi_hint,
        master_rel: $master_rel,
        master_hint: $master_hint,
        callname: $callname,
        chara: $chara,
        chara_hint: $chara_hint,
        prof: $prof
      },
      render_persona: {
        effective_gender: $effective_gender,
        effective_visual_age: $effective_visual_age,
        effective_era: $effective_era,
        expression_mode: $expression_mode,
        pose_mode: $pose_mode,
        prop_mode: $prop_mode
      },
      prompt: $prompt,
      negative_prompt: $negative_prompt,
      prompt_hash: $prompt_hash,
      api: {
        endpoint: $endpoint,
        response_modalities: ["image"],
        aspect_ratio: $aspect_ratio
      },
      postprocess: {
        face_crop: $face_crop
      },
      response_preview: (
        if ($response_json | length) > 0 then
          ($response_json[0] | del(.predictions[0].bytesBase64Encoded, .predictions[0].image.bytesBase64Encoded, .generatedImages[0].image.imageBytes, .generatedImages[0].image.bytesBase64Encoded, .candidates[0].content.parts))
        else
          {}
        end
      )
    }' > "$meta_tmp"
  mv "$meta_tmp" "$meta_path"
}

generate_background() {
  local project_input="$1"
  local role="$2"
  local refresh_flag="$3"
  local prof_override="${4:-}"
  local project=""
  local cache_dir=""
  local image_path=""
  local meta_path=""
  local persona_output=""
  local persona_line=""
  local gender_desc=""
  local age_desc=""
  local named_prompt=""
  local fallback_prompt=""
  local negative_prompt=""
  local api_key_value=""
  local vertex_project=""
  local vertex_location=""
  local tmp_dir=""
  local response_file=""
  local style_mode=""
  local generation_model=""
  local generation_prompt_version=""
  local generation_prompt_schema=""
  local selection_reason=""
  local has_image="false"
  local has_meta="false"
  local generation_lock=""
  local lock_mtime=""
  local now_epoch=""

  # Trust the explicit --project path; do NOT resolve to git root
  # (a non-git subdir inside a git repo would resolve to the wrong parent)
  project="$(normalize_dir "$project_input")" || die "project path not found: $project_input"
  cache_dir="$(project_cache_dir "$project")"
  image_path="$(project_image_path "$project" "$role")"
  meta_path="$(project_meta_path "$project" "$role")"
  mkdir -p "$cache_dir"

  require_cmd "$CC_PERSONA_BIN"
  require_cmd jq
  require_cmd python3
  require_cmd base64
  require_cmd shasum
  python3 -c 'from google import genai' >/dev/null 2>&1 || die "python package google-genai is required"

  [[ -s "$image_path" ]] && has_image="true"
  [[ -s "$meta_path" ]] && has_meta="true"
  if [[ "$refresh_flag" != "true" ]] && [[ "$has_image" == "true" && "$has_meta" == "true" ]]; then
    printf '%s\n' "$image_path"
    return 0
  fi

  mkdir -p "$WORK_ROOT"
  generation_lock="$(generation_lock_dir "$project")"
  if [[ -d "$generation_lock" ]]; then
    lock_mtime="$(stat -f '%m' "$generation_lock" 2>/dev/null || printf '0')"
    now_epoch="$(date +%s)"
    if [[ "$lock_mtime" =~ ^[0-9]+$ ]] && (( now_epoch - lock_mtime > 300 )); then
      rm -rf "$generation_lock"
    fi
  fi
  while ! mkdir "$generation_lock" 2>/dev/null; do
    sleep 1
    lock_mtime="$(stat -f '%m' "$generation_lock" 2>/dev/null || printf '0')"
    now_epoch="$(date +%s)"
    if [[ "$lock_mtime" =~ ^[0-9]+$ ]] && (( now_epoch - lock_mtime > 300 )); then
      rm -rf "$generation_lock"
    fi
  done

  persona_output="$(cd "$project" && "$CC_PERSONA_BIN")"
  if ! persona_line="$(parse_persona_output "$persona_output" "$role")"; then
    rm -rf "$generation_lock"
    return 1
  fi
  persona_line="$(apply_prof_override "$persona_line" "$prof_override")"
  set_persona_from_line "$persona_line" "$role"
  gender_desc="$(translate_gender "$PERSONA_GENDER_RAW")"
  age_desc="$(translate_age "$PERSONA_AGE_RAW")"
  negative_prompt="$(build_negative_prompt)"

  if [[ "$refresh_flag" == "true" ]]; then
    generation_model="$PRO_MODEL_NAME"
    if [[ "$has_image" == "true" && "$has_meta" != "true" ]]; then
      selection_reason="manual_refresh_unmanaged"
    else
      selection_reason="manual_refresh_pro"
    fi
  else
    generation_model="$PRO_MODEL_NAME"
    selection_reason="cache_miss"
  fi

  prepare_generation_prompts "$generation_model" "$role"

  api_key_value="$(api_key_or_empty)"
  vertex_project="$(vertex_project_or_empty)"
  vertex_location="$(vertex_location_or_default)"
  if [[ -z "$vertex_project" && -z "$api_key_value" ]]; then
    rm -rf "$generation_lock"
    die "no Vertex project or API key available for image generation"
  fi

  tmp_dir="$(mktemp -d)"
  response_file="${tmp_dir}/response.json"

  style_mode="$STYLE_MODE_NAMED"
  if ! generate_style_image "$named_prompt" "$negative_prompt" "$response_file" "$api_key_value" "$image_path" "$tmp_dir" "$generation_model" "$vertex_project" "$vertex_location"; then
    if [[ "$generation_model" == "$PRO_MODEL_NAME" ]] && generation_error_is_flash_recoverable; then
      generation_model="$FLASH_MODEL_NAME"
      prepare_generation_prompts "$generation_model" "$role"
      selection_reason="${selection_reason}_flash_fallback"
      generate_style_image "$named_prompt" "$negative_prompt" "$response_file" "$api_key_value" "$image_path" "$tmp_dir" "$generation_model" "$vertex_project" "$vertex_location" || {
        rm -rf "$tmp_dir"
        rm -rf "$generation_lock"
        die "image generation did not produce a usable text-free image"
      }
    else
      style_mode="$STYLE_MODE_FALLBACK"
      : > "$response_file"
      if ! generate_style_image "$fallback_prompt" "$negative_prompt" "$response_file" "$api_key_value" "$image_path" "$tmp_dir" "$generation_model" "$vertex_project" "$vertex_location"; then
        if [[ "$generation_model" == "$PRO_MODEL_NAME" ]] && generation_error_is_flash_recoverable; then
          generation_model="$FLASH_MODEL_NAME"
          prepare_generation_prompts "$generation_model" "$role"
          selection_reason="${selection_reason}_flash_fallback"
          generate_style_image "$fallback_prompt" "$negative_prompt" "$response_file" "$api_key_value" "$image_path" "$tmp_dir" "$generation_model" "$vertex_project" "$vertex_location" || {
            rm -rf "$tmp_dir"
            rm -rf "$generation_lock"
            die "image generation did not produce a usable text-free image"
          }
        else
          rm -rf "$tmp_dir"
          rm -rf "$generation_lock"
          die "image generation did not produce a usable text-free image"
        fi
      fi
    fi
  fi

  if [[ "$style_mode" == "$STYLE_MODE_NAMED" ]]; then
    write_sidecar "$meta_path" "$project" "$role" "$style_mode" "$named_prompt" "$negative_prompt" "$persona_line" "$image_path" "$response_file" "$gender_desc" "$age_desc" "$generation_model" "$generation_prompt_version" "$generation_prompt_schema" "$selection_reason"
  else
    write_sidecar "$meta_path" "$project" "$role" "$style_mode" "$fallback_prompt" "$negative_prompt" "$persona_line" "$image_path" "$response_file" "$gender_desc" "$age_desc" "$generation_model" "$generation_prompt_version" "$generation_prompt_schema" "$selection_reason"
  fi

  rm -rf "$tmp_dir"
  rm -rf "$generation_lock"
  printf '%s\n' "$image_path"
}

resolve_pane_project() {
  local project_hint="$1"
  local pane_cwd="$2"
  local resolved=""

  if [[ -n "$project_hint" ]]; then
    if resolved="$(normalize_dir "$project_hint" 2>/dev/null)"; then
      printf '%s' "$resolved"
      return 0
    fi
    if [[ "$project_hint" != /* ]] && [[ -d "${pane_cwd}/${project_hint}" ]]; then
      resolved="$(normalize_dir "${pane_cwd}/${project_hint}")"
      printf '%s' "$resolved"
      return 0
    fi
  fi

  if [[ -n "$pane_cwd" && -d "$pane_cwd" ]]; then
    if resolved="$(detect_project_root "$pane_cwd" 2>/dev/null)"; then
      printf '%s' "$resolved"
      return 0
    fi
  fi

  return 1
}

install_sync_hooks() {
  local session="$1"
  local fast_hook_cmd=""
  local full_hook_cmd=""
  local hook_log=""
  local fast_hooks=(
    window-layout-changed
    window-resized
    client-resized
    after-resize-pane
    after-resize-window
    after-select-layout
    after-swap-pane
  )
  local full_hooks=(
    after-split-window
    after-kill-pane
  )
  local hook_name=""

  hook_log="$(hook_log_path "$session")"
  mkdir -p "$WORK_ROOT"
  : >> "$hook_log"

  fast_hook_cmd="'$(single_quote_escape "$SCRIPT_PATH")' sync --session '$(single_quote_escape "$session")' --fast >/dev/null 2>>'$(single_quote_escape "$hook_log")' || true"
  full_hook_cmd="'$(single_quote_escape "$SCRIPT_PATH")' sync --session '$(single_quote_escape "$session")' >/dev/null 2>>'$(single_quote_escape "$hook_log")' || true"

  for hook_name in "${fast_hooks[@]}"; do
    tmux set-hook -t "$session" "$hook_name" "run-shell -b \"${fast_hook_cmd}\"" >/dev/null 2>&1 || true
  done
  for hook_name in "${full_hooks[@]}"; do
    tmux set-hook -t "$session" "$hook_name" "run-shell -b \"${full_hook_cmd}\"" >/dev/null 2>&1 || true
  done
}

resolve_cached_background() {
  local project="$1"
  local role="$2"
  local image_path=""
  local meta_path=""

  image_path="$(project_image_path "$project" "$role")"
  meta_path="$(project_meta_path "$project" "$role")"
  [[ -s "$image_path" ]] || return 1
  [[ -s "$meta_path" ]] || meta_path=""
  printf '%s\t%s\n' "$image_path" "$meta_path"
}

pick_manifest_image_candidate() {
  local manifest_path="$1"
  local candidate=""
  shift

  [[ -s "$manifest_path" ]] || return 1
  candidate="$(jq -r "$@" "$manifest_path" 2>/dev/null | head -n 1)"
  [[ -n "$candidate" && "$candidate" != "null" && -s "$candidate" ]] || return 1
  printf '%s' "$candidate"
}

resolve_placeholder_background() {
  local project="$1"
  local role="$2"
  local pane_id="${3:-}"
  local candidate=""

  if [[ -n "$pane_id" ]]; then
    candidate="$(pick_manifest_image_candidate "$CURRENT_MANIFEST" \
      --arg pane_id "$pane_id" --arg project "$project" --arg role "$role" \
      '.panes[] | select((.pane_id // "") == $pane_id and (.project // "") == $project and (.role // "") == $role and (.image_path // "") != "") | .image_path' \
      2>/dev/null || true)"
    if [[ -n "$candidate" && -s "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  candidate="$(pick_manifest_image_candidate "$CURRENT_MANIFEST" \
    --arg project "$project" --arg role "$role" \
    '.panes[] | select((.project // "") == $project and (.role // "") == $role and (.image_path // "") != "") | .image_path' \
    2>/dev/null || true)"
  if [[ -n "$candidate" && -s "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="$(runtime_placeholder_path "$role")"
  if [[ -s "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  if candidate="$(ensure_runtime_placeholder "$role" 2>/dev/null)"; then
    [[ -n "$candidate" && -s "$candidate" ]] || return 1
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

schedule_generation_retry() {
  local session="$1"
  local project="$2"
  local role="$3"
  local hook_log=""
  local lock_dir=""
  local lock_mtime=""
  local now_epoch=""

  hook_log="$(hook_log_path "$session")"
  lock_dir="$(generation_retry_lock_dir "$session" "$project" "$role")"
  mkdir -p "$WORK_ROOT"

  if [[ -d "$lock_dir" ]]; then
    lock_mtime="$(stat -f '%m' "$lock_dir" 2>/dev/null || printf '0')"
    now_epoch="$(date +%s)"
    if [[ "$lock_mtime" =~ ^[0-9]+$ ]] && (( now_epoch - lock_mtime > 300 )); then
      rm -rf "$lock_dir"
    fi
  fi
  if [[ -d "$lock_dir" ]]; then
    return 0
  fi
  if ! mkdir "$lock_dir" 2>/dev/null; then
    return 0
  fi

  nohup "$SCRIPT_PATH" retry-worker \
    --session "$session" \
    --project "$project" \
    --role "$role" \
    >>"$hook_log" 2>&1 &
}

retry_generate_background() {
  local session="$1"
  local project="$2"
  local role="$3"
  local lock_dir=""
  local generated_image_path=""
  local generated_meta_path=""
  local delay=""
  local -a retry_delays=(10 30 90)

  lock_dir="$(generation_retry_lock_dir "$session" "$project" "$role")"
  mkdir -p "$WORK_ROOT"
  if [[ ! -d "$lock_dir" ]]; then
    if ! mkdir "$lock_dir" 2>/dev/null; then
      return 0
    fi
  fi

  trap "rm -rf '${lock_dir}'" EXIT

  for delay in "${retry_delays[@]}"; do
    sleep "$delay"

    if ! tmux has-session -t "$session" >/dev/null 2>&1; then
      warn "retry worker: tmux session vanished for ${project} (${role}); stopping retries"
      return 0
    fi

    if generated_image_path="$(generate_background "$project" "$role" "false")"; then
      generated_meta_path="$(project_meta_path "$project" "$role")"
      if [[ -s "$generated_image_path" && -s "$generated_meta_path" ]]; then
        if ! "$SCRIPT_PATH" sync --session "$session" --fast >/dev/null; then
          warn "retry worker: generated ${project} (${role}) but failed to refresh manifest"
        fi
        warn "retry worker: generated ${project} (${role}) and refreshed manifest"
        return 0
      fi
    fi

    warn "retry worker: image generation failed for ${project} (${role}); next retry pending"
  done

  warn "retry worker: exhausted retries for ${project} (${role}); keeping placeholder"
  return 0
}

update_manifest_pane_assets() {
  local panes_array_file="$1"
  local pane_id="$2"
  local image_path="$3"
  local meta_path="$4"
  local tmp_file=""

  tmp_file="$(mktemp "${panes_array_file}.tmp.XXXXXX")"

  jq \
    --arg pane_id "$pane_id" \
    --arg image_path "$image_path" \
    --arg meta_path "$meta_path" \
    'map(
      if .pane_id == $pane_id then
        .image_path = (if $image_path == "" then null else $image_path end)
        | .image_meta_path = (if $meta_path == "" then null else $meta_path end)
      else
        .
      end
    )' "$panes_array_file" > "$tmp_file"
  mv "$tmp_file" "$panes_array_file"
}

write_manifest() {
  local session="$1"
  local manifest_path="$2"
  local panes_array_file="$3"
  local window_name="$4"
  local window_layout="$5"
  local window_width="$6"
  local window_height="$7"
  local manifest_tmp=""

  manifest_tmp="$(mktemp "${manifest_path}.tmp.XXXXXX")"

  jq -n \
    --arg session "$session" \
    --arg window "$window_name" \
    --arg window_layout "$window_layout" \
    --arg generated_at "$(now_utc)" \
    --arg script_path "$SCRIPT_PATH" \
    --arg current_manifest "$CURRENT_MANIFEST" \
    --arg opacity "$DEFAULT_OPACITY" \
    --argjson window_width "$window_width" \
    --argjson window_height "$window_height" \
    --slurpfile panes "$panes_array_file" \
    '{
      version: 1,
      session: $session,
      window: $window,
      generated_at: $generated_at,
      source_script: $script_path,
      current_manifest: $current_manifest,
      default_opacity: ($opacity | tonumber),
      window_layout: $window_layout,
      window_cells: {
        width: $window_width,
        height: $window_height
      },
      panes: $panes[0]
    }' > "$manifest_tmp"
  mv "$manifest_tmp" "$manifest_path"
  cp "$manifest_path" "${CURRENT_MANIFEST}.tmp"
  mv "${CURRENT_MANIFEST}.tmp" "$CURRENT_MANIFEST"
}

sync_session() {
  local session="$1"
  local sync_mode="${2:-full}"
  local target="${session}:dev"
  local lock_dir=""
  local pending_file=""
  local tmp_dir=""
  local panes_jsonl=""
  local panes_array_file=""
  local pane_rows_file=""
  local pending_generate_file=""
  local manifest_path=""
  local meta_path=""
  local dims=""
  local window_width=""
  local window_height=""
  local window_name=""
  local window_layout=""
  local pane_id=""
  local pane_left=""
  local pane_top=""
  local pane_width=""
  local pane_height=""
  local pane_cwd=""
  local tmux_role=""
  local pane_alias=""
  local pane_column=""
  local project_hint=""
  local role=""
  local project=""
  local image_path=""
  local asset_fields=""
  local placeholder_path=""
  local pending_pane_id=""
  local pending_project=""
  local pending_role=""
  local generated_image_path=""
  local generated_meta_path=""
  local lock_mtime=""
  local now_epoch=""

  require_cmd tmux
  require_cmd jq
  require_cmd shasum

  tmux has-session -t "$session" >/dev/null 2>&1 || die "tmux session not found: $session"
  tmux list-windows -t "$target" >/dev/null 2>&1 || die "tmux window not found: ${target}"
  prime_session_api_env "$session"
  hydrate_api_env_from_session "$session"

  mkdir -p "$WORK_ROOT"
  ensure_all_runtime_placeholders
  lock_dir="${WORK_ROOT}/lock.$(safe_name "$session")"
  pending_file="${WORK_ROOT}/pending.$(safe_name "$session")"
  if [[ -d "$lock_dir" ]]; then
    lock_mtime="$(stat -f '%m' "$lock_dir" 2>/dev/null || printf '0')"
    now_epoch="$(date +%s)"
    if [[ "$lock_mtime" =~ ^[0-9]+$ ]] && (( now_epoch - lock_mtime > 120 )); then
      rm -rf "$lock_dir"
    fi
  fi
  if ! mkdir "$lock_dir" 2>/dev/null; then
    : > "$pending_file"
    printf '%s\n' "${WORK_ROOT}/$(safe_name "$session").json"
    return 0
  fi

  manifest_path="${WORK_ROOT}/$(safe_name "$session").json"

  install_sync_hooks "$session"
  while true; do
    rm -f "$pending_file"

    tmp_dir="$(mktemp -d)"
    panes_jsonl="${tmp_dir}/panes.jsonl"
    panes_array_file="${tmp_dir}/panes-array.json"
    pane_rows_file="${tmp_dir}/pane-rows.txt"
    pending_generate_file="${tmp_dir}/pending-generate.txt"
    : > "$panes_jsonl"
    : > "$pending_generate_file"

    dims="$(tmux display-message -p -t "$target" '#{window_width}	#{window_height}	#{window_name}	#{window_layout}')"
    IFS=$'\t' read -r window_width window_height window_name window_layout <<< "$dims"

    tmux list-panes -t "$target" -F '#{pane_id}|#{pane_left}|#{pane_top}|#{pane_width}|#{pane_height}|#{pane_current_path}|#{@role}|#{@alias}|#{@column}|#{@project}' > "$pane_rows_file"

    while IFS='|' read -r pane_id pane_left pane_top pane_width pane_height pane_cwd tmux_role pane_alias pane_column project_hint <&3; do
      [[ -n "$pane_id" ]] || continue
      if ! role="$(classify_tmux_role "$tmux_role" 2>/dev/null)"; then
        continue
      fi

      project=""
      image_path=""
      meta_path=""
      placeholder_path=""

      if project="$(resolve_pane_project "$project_hint" "$pane_cwd" 2>/dev/null)"; then
        if asset_fields="$(resolve_cached_background "$project" "$role" 2>/dev/null)"; then
          IFS=$'\t' read -r image_path meta_path <<< "$asset_fields"
          if [[ -z "$meta_path" && "$sync_mode" != "fast" ]]; then
            printf '%s|%s|%s\n' "$pane_id" "$project" "$role" >> "$pending_generate_file"
          fi
        else
          if placeholder_path="$(resolve_placeholder_background "$project" "$role" "$pane_id" 2>/dev/null)"; then
            image_path="$placeholder_path"
          fi
          if [[ "$sync_mode" != "fast" ]]; then
            printf '%s|%s|%s\n' "$pane_id" "$project" "$role" >> "$pending_generate_file"
          fi
        fi
      else
        warn "could not resolve project for pane ${pane_id}"
      fi

      jq -n \
        --arg pane_id "$pane_id" \
        --arg tmux_role "$tmux_role" \
        --arg role "$role" \
        --arg alias "$pane_alias" \
        --arg column "$pane_column" \
        --arg pane_cwd "$pane_cwd" \
        --arg project "${project:-}" \
        --arg image_path "${image_path:-}" \
        --arg meta_path "${meta_path:-}" \
        --arg opacity "$DEFAULT_OPACITY" \
        --argjson left "$pane_left" \
        --argjson top "$pane_top" \
        --argjson width "$pane_width" \
        --argjson height "$pane_height" \
        '{
          pane_id: $pane_id,
          tmux_role: $tmux_role,
          role: $role,
          alias: (if $alias == "" then null else $alias end),
          column: (if $column == "" then null else $column end),
          pane_cwd: $pane_cwd,
          project: (if $project == "" then null else $project end),
          left: $left,
          top: $top,
          width: $width,
          height: $height,
          image_path: (if $image_path == "" then null else $image_path end),
          image_meta_path: (if $meta_path == "" then null else $meta_path end),
          opacity: ($opacity | tonumber)
        }' >> "$panes_jsonl"
    done 3< "$pane_rows_file"

    jq -s '.' "$panes_jsonl" > "$panes_array_file"
    write_manifest "$session" "$manifest_path" "$panes_array_file" "$window_name" "$window_layout" "$window_width" "$window_height"
    tmux set-environment -t "$session" TPROJ_PANE_BG_ENABLE 1
    tmux set-environment -t "$session" TPROJ_PANE_BG_MANIFEST "$manifest_path"

    if [[ "$sync_mode" != "fast" && -s "$pending_generate_file" ]]; then
      while IFS='|' read -r pending_pane_id pending_project pending_role; do
        [[ -n "$pending_pane_id" && -n "$pending_project" && -n "$pending_role" ]] || continue
        if generated_image_path="$(generate_background "$pending_project" "$pending_role" "false")"; then
          generated_meta_path="$(project_meta_path "$pending_project" "$pending_role")"
          update_manifest_pane_assets "$panes_array_file" "$pending_pane_id" "$generated_image_path" "$generated_meta_path"
          write_manifest "$session" "$manifest_path" "$panes_array_file" "$window_name" "$window_layout" "$window_width" "$window_height"
          tmux set-environment -t "$session" TPROJ_PANE_BG_ENABLE 1
          tmux set-environment -t "$session" TPROJ_PANE_BG_MANIFEST "$manifest_path"
        else
          warn "image generation failed for ${pending_project} (${pending_role}); keeping placeholder"
          schedule_generation_retry "$session" "$pending_project" "$pending_role"
        fi
      done < "$pending_generate_file"
    fi

    rm -rf "$tmp_dir"

    [[ -e "$pending_file" ]] || break
  done

  if [[ "$sync_mode" != "fast" ]]; then
    while IFS='|' read -r fb_pane_id fb_project fb_role; do
      [[ -n "$fb_pane_id" ]] || continue
      schedule_generation_retry "$session" "$fb_project" "$fb_role"
    done < <(jq -r '.panes[] | select(.image_path != null and (.image_path | test("fallback-"))) | "\(.pane_id)|\(.project)|\(.role)"' "$manifest_path" 2>/dev/null)
  fi

  rm -f "$pending_file"
  rm -rf "$lock_dir"
  printf '%s\n' "$manifest_path"
}

cmd_generate() {
  local project=""
  local role=""
  local refresh="false"
  local prof_override=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project)
        [[ $# -ge 2 ]] || die "missing value for --project"
        project="$2"
        shift 2
        ;;
      --role)
        [[ $# -ge 2 ]] || die "missing value for --role"
        role="$2"
        shift 2
        ;;
      --prof)
        [[ $# -ge 2 ]] || die "missing value for --prof"
        prof_override="$2"
        shift 2
        ;;
      --refresh)
        refresh="true"
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        die "unknown option for generate: $1"
        ;;
    esac
  done

  [[ -n "$project" ]] || die "generate requires --project"
  [[ "$role" == "cc" || "$role" == "cdx" ]] || die "generate requires --role cc|cdx"
  generate_background "$project" "$role" "$refresh" "$prof_override"
}

cmd_sync() {
  local session=""
  local sync_mode="full"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session)
        [[ $# -ge 2 ]] || die "missing value for --session"
        session="$2"
        shift 2
        ;;
      --fast)
        sync_mode="fast"
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        die "unknown option for sync: $1"
        ;;
    esac
  done

  [[ -n "$session" ]] || die "sync requires --session"
  sync_session "$session" "$sync_mode"
}

cmd_retry_worker() {
  local session=""
  local project=""
  local role=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session)
        [[ $# -ge 2 ]] || die "missing value for --session"
        session="$2"
        shift 2
        ;;
      --project)
        [[ $# -ge 2 ]] || die "missing value for --project"
        project="$2"
        shift 2
        ;;
      --role)
        [[ $# -ge 2 ]] || die "missing value for --role"
        role="$2"
        shift 2
        ;;
      *)
        die "unknown option for retry-worker: $1"
        ;;
    esac
  done

  [[ -n "$session" ]] || die "retry-worker requires --session"
  [[ -n "$project" ]] || die "retry-worker requires --project"
  [[ "$role" == "cc" || "$role" == "cdx" ]] || die "retry-worker requires --role cc|cdx"

  prime_session_api_env "$session"
  hydrate_api_env_from_session "$session"
  retry_generate_background "$session" "$project" "$role"
}

cmd_hook() {
  local session=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session)
        [[ $# -ge 2 ]] || die "missing value for --session"
        session="$2"
        shift 2
        ;;
      --window|--mode|--root|--remote-host)
        [[ $# -ge 2 ]] || die "missing value for $1"
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        die "unknown hook option: $1"
        ;;
    esac
  done

  [[ -n "$session" ]] || die "hook invocation requires --session"
  sync_session "$session" "full"
}

main() {
  mkdir -p "$WORK_ROOT"
  case "${1:-}" in
    generate)
      shift
      cmd_generate "$@"
      ;;
    sync)
      shift
      cmd_sync "$@"
      ;;
    retry-worker)
      shift
      cmd_retry_worker "$@"
      ;;
    --*)
      cmd_hook "$@"
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      die "unknown command: $1"
      ;;
  esac
}

main "$@"
