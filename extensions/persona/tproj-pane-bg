set_persona_from_line() {
  local persona_line="$1"
  local role="$2"
  local payload="${persona_line#CC  Persona: }"
  payload="${payload#Cdx Persona: }"
  local -a parts=()
  local head="" tail=""
  local chi_field="" master_field="" callname_field="" chara_field=""

  reset_persona_globals
  PERSONA_ROLE="$role"
  IFS='/' read -r -a parts <<< "$payload"
  [[ ${#parts[@]} -ge 6 ]] || die "unexpected persona format: ${persona_line}"

  PERSONA_MBTI="$(trim "${parts[0]}")"
  PERSONA_GENDER_RAW="$(trim "${parts[1]}")"
  PERSONA_AGE_RAW="$(trim "${parts[2]}")"
  PERSONA_ERA="$(trim "${parts[3]}")"
  PERSONA_TONE="$(trim "${parts[4]}")"

  head="${payload#*/}"
  head="${head#*/}"
  head="${head#*/}"
  head="${head#*/}"
  head="${head#*/}"
  tail="$(trim "$head")"

  [[ "$tail" == chi-rel:* ]] || die "unexpected persona tail format: ${persona_line}"
  chi_field="${tail%% / master-rel:*}"
  tail="${tail#"$chi_field"}"
  tail="${tail# / }"

  [[ "$tail" == master-rel:* ]] || die "unexpected master-rel format: ${persona_line}"
  master_field="${tail%% / callname:*}"
  tail="${tail#"$master_field"}"
  tail="${tail# / }"

  [[ "$tail" == callname:* ]] || die "unexpected callname format: ${persona_line}"
  callname_field="${tail%% / chara:*}"
  tail="${tail#"$callname_field"}"
  tail="${tail# / }"

  [[ "$tail" == chara:* ]] || die "unexpected chara format: ${persona_line}"
  local prof_field=""
  if [[ "$tail" == *" / prof:"* ]]; then
    chara_field="${tail%% / prof:*}"
    prof_field="${tail#*/ prof:}"
  else
    chara_field="$tail"
  fi

  PERSONA_CHI_REL="${chi_field#chi-rel:}"
  PERSONA_MASTER_REL="${master_field#master-rel:}"
  PERSONA_CALLNAME="${callname_field#callname:}"
  PERSONA_CHARA="${chara_field#chara:}"
  PERSONA_PROF="$(trim "$prof_field")"

  PERSONA_ERA_HINT="$(describe_era_hint "$PERSONA_ERA")"
  PERSONA_TONE_HINT="$(describe_tone_hint "$PERSONA_TONE")"
  PERSONA_CHI_HINT="$PERSONA_CHI_REL"
  PERSONA_MASTER_HINT="$(describe_master_hint "$PERSONA_MASTER_REL")"
  PERSONA_CHARA_HINT="$(describe_chara_hint "$PERSONA_CHARA")"
  PERSONA_VISUAL_AGE="$(visual_age_value "$role")"
  PERSONA_EXPRESSION_MODE="$(expression_mode_value)"
  PERSONA_POSE_MODE="$(pose_mode_value)"
  PERSONA_PROP_MODE="$(prop_mode_value)"
}

