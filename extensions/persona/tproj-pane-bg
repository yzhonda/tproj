usage() {
  cat <<'EOF'
Usage:
  tproj-pane-bg --session <name> [--window <name>] [--mode <single|workspace>]
  tproj-pane-bg generate --project <path> --role cc|cdx [--prof <value>] [--refresh]
  tproj-pane-bg sync --session <name>

Commands:
  generate   Generate or reuse a cached vertical wallpaper for cc/cdx.
  sync       Collect tmux pane geometry, refresh the manifest, and install hooks.
  --prof     Override only the persona profession field for image generation.
EOF
}

die() {
  echo "${PROGRAM_NAME}: $*" >&2
  exit 1
}

warn() {
  echo "${PROGRAM_NAME}: $*" >&2
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

safe_name() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'
}

hash_string() {
  printf '%s' "$1" | shasum -a 256 | awk '{print $1}'
}

decode_base64_to_file() {
  local encoded="$1"
  local out_path="$2"
  if base64 --help 2>&1 | grep -q -- '--decode'; then
    printf '%s' "$encoded" | base64 --decode > "$out_path"
  else
    printf '%s' "$encoded" | base64 -D > "$out_path"
  fi
}

single_quote_escape() {
  printf '%s' "$1" | sed "s/'/'\\\\''/g"
}

normalize_dir() {
  local path="$1"
  if [[ -d "$path" ]]; then
    (cd "$path" && pwd -P)
    return 0
  fi
  return 1
}

detect_project_root() {
  local path="$1"
  if git -C "$path" rev-parse --show-toplevel >/dev/null 2>&1; then
    git -C "$path" rev-parse --show-toplevel
  else
    normalize_dir "$path"
  fi
}

project_cache_dir() {
  printf '%s/.local/tproj-pane-bg' "$1"
}

project_image_path() {
  local project="$1"
  local role="$2"
  printf '%s/%s.vertical.png' "$(project_cache_dir "$project")" "$role"
}

project_meta_path() {
