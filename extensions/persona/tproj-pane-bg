}

runtime_placeholder_path() {
  local role="$1"
  printf '%s/fallback-%s.png' "$WORK_ROOT" "$role"
}

hook_log_path() {
  local session="$1"
  printf '%s/hook.%s.log' "$WORK_ROOT" "$(safe_name "$session")"
}

generation_retry_lock_dir() {
  local session="$1"
  local project="$2"
  local role="$3"
  printf '%s/retry.%s.%s.%s.lock' "$WORK_ROOT" "$(safe_name "$session")" "$(safe_name "$project")" "$role"
}

generation_lock_dir() {
  local project="$1"
  printf '%s/generate.%s.lock' "$WORK_ROOT" "$(safe_name "$project")"
}

ensure_runtime_placeholder() {
  local role="$1"
  local out_path=""
  local base_gradient=""
  local overlay_gradient=""
  local glow_color=""
  local accent_color=""
  local tmp_path=""

  out_path="$(runtime_placeholder_path "$role")"
  [[ -s "$out_path" ]] && {
    printf '%s\n' "$out_path"
    return 0
  }

  command -v magick >/dev/null 2>&1 || return 1
  mkdir -p "$WORK_ROOT"
  tmp_path="${out_path}.tmp.png"

  case "$role" in
    cc)
      base_gradient="#3f2b35-#b88b92"
      overlay_gradient="#f4ddd3-#00000000"
      glow_color="#f9e8e0aa"
      accent_color="#f3cbbd66"
      ;;
    cdx|*)
      base_gradient="#213346-#6d8da9"
      overlay_gradient="#dce8f4-#00000000"
      glow_color="#e7f2ffaa"
      accent_color="#bed7f766"
      ;;
  esac

  if ! magick \
    -size "${TARGET_WIDTH}x${TARGET_HEIGHT}" "gradient:${base_gradient}" \
    \( -size "${TARGET_WIDTH}x${TARGET_HEIGHT}" "radial-gradient:${overlay_gradient}" -alpha set -channel A -evaluate multiply 0.50 +channel \) -compose screen -composite \
    \( -size "${TARGET_WIDTH}x${TARGET_HEIGHT}" xc:none -fill "${glow_color}" -draw "ellipse 512,700 210,320 0,360" -blur 0x80 \) -compose over -composite \
    \( -size "${TARGET_WIDTH}x${TARGET_HEIGHT}" xc:none -fill "${accent_color}" -draw "ellipse 512,1020 360,260 0,360" -blur 0x110 \) -compose screen -composite \
    -strip "$tmp_path" >/dev/null 2>&1; then
    rm -f "$tmp_path"
    return 1
  fi

  mv "$tmp_path" "$out_path"
  printf '%s\n' "$out_path"
}

ensure_all_runtime_placeholders() {
  ensure_runtime_placeholder "cc" >/dev/null 2>&1 || true
  ensure_runtime_placeholder "cdx" >/dev/null 2>&1 || true
}

api_key_or_empty() {
