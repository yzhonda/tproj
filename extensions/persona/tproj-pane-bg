request_imagen() {
  local prompt="$1"
  local negative_prompt="$2"
  local response_file="$3"
  local api_key_value="$4"
  local model_name="$5"
  local vertex_project="$6"
  local vertex_location="$7"
  local error_file="${8:-${response_file}.error.json}"
  python3 - "$prompt" "$negative_prompt" "$response_file" "$api_key_value" "$ASPECT_RATIO" "$model_name" "$vertex_project" "$vertex_location" "$error_file" "$REQUEST_TIMEOUT_SECONDS" <<'PY'
import base64
import json
import signal
import sys

from google import genai

prompt, negative_prompt, response_path, api_key, aspect_ratio, model_name, vertex_project, vertex_location, error_path, request_timeout = sys.argv[1:11]
request_timeout = int(request_timeout)

full_prompt = (
    prompt
    + "\n\n絶対条件:\n"
    + negative_prompt
    + "\n文字は一切入れない。読める文字、記号、ラベル、看板、背表紙、メモ、UI、数字、刻印を出さない。"
    + "\nNO READABLE TEXT ANYWHERE. NO TITLE. NO CAPTION. NO SUBTITLE. NO LETTERS. NO NUMBERS. NO SYMBOLS."
    + "\n古典的な肖像画の構図。顔と上半身が自然に大きく見える、均整の取れた半身ポートレートにする。頭上の余白を少なくし、人物を一番大きく見せる。"
    + "\n表情と肩と手の動きを必ず入れる。無表情な証明写真や静止 bust にしない。"
)

last_error = None
response = None

def write_error(kind, message, *, code=None, status=None, exception_type=None):
    payload = {
        "kind": kind,
        "message": message,
        "code": code,
        "status": status,
        "exception_type": exception_type,
    }
    with open(error_path, "w", encoding="utf-8") as f:
        json.dump(payload, f)


class RequestTimedOut(Exception):
    pass


def _alarm_handler(signum, frame):
    raise RequestTimedOut(f"image generation request exceeded {request_timeout}s timeout")


def generate_with_timeout(client, *, model, contents, config):
    previous = signal.signal(signal.SIGALRM, _alarm_handler)
    signal.alarm(request_timeout)
    try:
        return client.models.generate_content(
            model=model,
            contents=contents,
            config=config,
        )
    finally:
        signal.alarm(0)
        signal.signal(signal.SIGALRM, previous)

if vertex_project:
    try:
        client = genai.Client(
            vertexai=True,
            project=vertex_project,
            location=vertex_location or "global",
        )
        response = generate_with_timeout(
            client,
            model=model_name,
            contents=full_prompt,
            config={
                "response_modalities": ["image"],
            },
        )
    except Exception as exc:
        last_error = exc

if response is None and api_key:
    try:
        client = genai.Client(api_key=api_key)
        response = generate_with_timeout(
            client,
            model=model_name,
            contents=full_prompt,
            config={
                "response_modalities": ["image"],
            },
        )
    except Exception as exc:
        last_error = exc

if response is None:
    if last_error is not None:
        status_code = getattr(last_error, "status_code", None)
        response_json = getattr(last_error, "response_json", None)
        error_status = None
        if isinstance(response_json, dict):
            error_status = ((response_json.get("error") or {}).get("status"))
        error_kind = "request_timeout" if isinstance(last_error, RequestTimedOut) else "api_error"
        write_error(
            error_kind,
            str(last_error),
            code=status_code,
            status=error_status,
            exception_type=type(last_error).__name__,
        )
        raise last_error
    message = "No usable Vertex AI ADC or API key auth path for image generation"
    write_error("auth_unavailable", message, exception_type="SystemExit")
    raise SystemExit(message)

preview = {"predictions": []}
for candidate in getattr(response, "candidates", []) or []:
    content = getattr(candidate, "content", None)
    for part in getattr(content, "parts", []) or []:
        inline = getattr(part, "inline_data", None)
        if not inline:
            continue
        data = getattr(inline, "data", None)
        if not data:
            continue
        mime_type = getattr(inline, "mime_type", None) or getattr(inline, "mimeType", None) or "image/png"
        if isinstance(data, str):
            try:
                binary = base64.b64decode(data)
            except Exception:
                binary = data.encode("utf-8")
        else:
            binary = bytes(data)
        preview["predictions"].append(
            {
                "bytesBase64Encoded": base64.b64encode(binary).decode("ascii"),
                "mimeType": mime_type,
            }
        )

if not preview["predictions"]:
    message = "No image data in Nano Banana response"
    write_error("no_image_data", message, exception_type="SystemExit")
    raise SystemExit(message)

with open(response_path, "w", encoding="utf-8") as f:
    json.dump(preview, f)

with open(error_path, "w", encoding="utf-8") as f:
    json.dump({"kind": "none", "message": ""}, f)
PY
}

