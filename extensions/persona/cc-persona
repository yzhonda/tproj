voice_expand_template_preview() {
  local template="$1" project_reading="$2" tool="$3" voice_gender="$4" callname="$5"
  local tool_reading
  tool_reading="$(voice_tool_reading "$tool")"
  template="${template//\{project_reading\}/$project_reading}"
  template="${template//\{tool_reading\}/$tool_reading}"
  template="${template//\{voice_gender\}/$voice_gender}"
  template="${template//\{callname\}/$callname}"
  template="${template//\{display_name\}/$project_reading}"
  template="${template//\{project_name\}/$project_reading}"
  printf '%s' "$template"
}

emit_voice_template_json_capped() {
  local id="$1" tool="$2" text="$3" fallback="$4" max_len="$5" speaker="$6" style="$7" gender="$8" callname="$9" project_reading="${10}"
  local preview
  preview="$(voice_expand_template_preview "$text" "$project_reading" "$tool" "$gender" "$callname")"
  if [[ ${#preview} -gt $max_len ]]; then
    text="$fallback"
    preview="$(voice_expand_template_preview "$text" "$project_reading" "$tool" "$gender" "$callname")"
    if [[ ${#preview} -gt $max_len ]]; then
      text="{project_reading}の{tool_reading}。"
    fi
  fi
  emit_voice_template_json "$id" "$tool" "$text" "$speaker" "$style" "$gender" "$callname"
}

