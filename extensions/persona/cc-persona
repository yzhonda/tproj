  # --- Get cwd (hook mode: reads JSON from stdin) ---
  INPUT=""
  if ! [ -t 0 ]; then
    INPUT=$(cat)
  fi

  CWD=""
  if [ -n "$INPUT" ]; then
    if command -v jq >/dev/null 2>&1; then
      CWD=$(echo "$INPUT" | jq -r '.cwd // empty' 2>/dev/null)
    fi
  fi
  if [ -z "$CWD" ]; then
