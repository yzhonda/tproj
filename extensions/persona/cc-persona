# --- Utility functions ---
md5hash() {
  echo -n "$1" | md5 -q 2>/dev/null || echo -n "$1" | md5sum | cut -d' ' -f1
}

hex_to_dec() {
  printf '%d' "0x$1"
}

pick_trait() {
  local digit="$1"
  shift
  local arr=("$@")
  local dec
  dec=$(hex_to_dec "$digit")
  local idx=$((dec % ${#arr[@]}))
  echo "${arr[$idx]}"
}

# --- --label mode: output short alias for pane labels ---
# Usage: cc-persona --label <project_path> <cc|cdx>
# Output: e.g. "江戸腹黒"
if [[ "${1:-}" == "--label" ]]; then
  LABEL_PATH="${2:?Usage: cc-persona --label <project_path> <cc|cdx>}"
  LABEL_KIND="${3:?Usage: cc-persona --label <project_path> <cc|cdx>}"
  LABEL_HASH=$(md5hash "$LABEL_PATH:$LABEL_KIND")
  LABEL_GENDER=$(role_fixed_gender "$LABEL_KIND")
  LABEL_ERA=$(pick_trait "${LABEL_HASH:3:1}" "${ERA[@]}")
  LABEL_CHARA=$(role_chara_trait "$LABEL_KIND" "${LABEL_HASH:7:1}")
  LABEL_ERA_S=$(era_short "$LABEL_ERA")
  LABEL_CHARA_S=$(chara_short "$LABEL_CHARA")
  LABEL_GENDER_MARK="♀"
  [[ "$LABEL_GENDER" == "男" ]] && LABEL_GENDER_MARK="♂"
  echo "${LABEL_GENDER_MARK}${LABEL_ERA_S}${LABEL_CHARA_S}"
  exit 0
fi

