#!/bin/zsh
set -euo pipefail
setopt KSH_ARRAYS  # 0-based array indexing (bash compatibility)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

resolve_tproj_runtime_root() {
  if [[ -n "${TPROJ_RUNTIME_ROOT:-}" && -d "${TPROJ_RUNTIME_ROOT}/bin" && -d "${TPROJ_RUNTIME_ROOT}/config" ]]; then
    echo "$TPROJ_RUNTIME_ROOT"
    return 0
  fi

  local parent
  parent="$(cd "$SCRIPT_DIR/.." && pwd)"
  if [[ -d "$parent/bin" && -d "$parent/config" ]]; then
    echo "$parent"
    return 0
  fi

  return 1
}

TPROJ_RUNTIME_ROOT="${TPROJ_RUNTIME_ROOT:-$(resolve_tproj_runtime_root 2>/dev/null || true)}"

runtime_bin_path() {
  local name="$1"
  local candidate=""

  if [[ -n "${TPROJ_RUNTIME_ROOT:-}" ]]; then
    candidate="$TPROJ_RUNTIME_ROOT/bin/$name"
    [[ -x "$candidate" ]] && { echo "$candidate"; return 0; }
  fi

  candidate="$HOME/bin/$name"
  [[ -x "$candidate" ]] && { echo "$candidate"; return 0; }

  command -v "$name" 2>/dev/null || return 1
}

quoted_runtime_bin_path() {
  local name="$1"
  local resolved
  resolved="$(runtime_bin_path "$name" 2>/dev/null || true)"
  [[ -n "$resolved" ]] && printf '%q' "$resolved"
}

run_rebalance_workspace() {
  local session="$1"
  local rebalance_path
  rebalance_path="$(runtime_bin_path "rebalance-workspace-columns" 2>/dev/null || true)"
  [[ -z "$rebalance_path" ]] && return 0
  "$rebalance_path" "$session" 2>/dev/null || true
}

mark_session_runtime() {
  local session="$1"
  tmux set-option -t "$session" @tproj true >/dev/null 2>&1 || true
  if [[ -n "${TPROJ_RUNTIME_ROOT:-}" ]]; then
    tmux set-option -t "$session" @tproj_runtime_root "$TPROJ_RUNTIME_ROOT" >/dev/null 2>&1 || true
  fi
  if [[ "$NO_GUI" == "true" ]]; then
    tmux set-option -t "$session" @tproj_gui_mode 1 >/dev/null 2>&1 || true
  fi
}

# Codex バイナリに署名（macOS コード署名問題の回避）
sign_codex() {
  if [[ "$(uname)" == "Darwin" ]]; then
    find /opt/homebrew/lib/node_modules/@openai/codex -type f \( -perm +111 -o -name "*.node" \) -exec codesign -s - -f {} \; 2>/dev/null || true
  fi
}

# 使い方:
#   tproj              # 現在ディレクトリからプロジェクト起動
#   tproj -s           # 単一プロジェクトモード強制（workspace.yaml 無視）
#   tproj -r host      # リモートホストにSSH接続して起動
#
# npm update は自動実行されません。手動で更新してください:
#   npm update -g @anthropic-ai/claude-code @openai/codex

show_help() {
  cat << 'EOF'
tproj - tmux project launcher

Usage:
  tproj [OPTIONS]
  tproj init           Interactive setup wizard (dependencies, workspace.yaml, hooks)
  tproj stop           Gracefully stop (Ctrl+C -> /exit -> wait -> kill)
  tproj kill           Immediately kill all tproj sessions (tmux kill-session)

Options:
  --add [ALIAS]      Add workspace column (no arg: duplicate current, with alias: from workspace.yaml)
  --check            Health check: dependencies, config, hooks status
  --no-gui           Skip GUI auto-launch (used by the app bundle)
  --repair           Repair pane tags (@alias, @column, pane_title) from @role + @project
  --sync-ui          Reapply pane title format + hooks to live tproj sessions
  -c, --columns N    Start with only the first N projects from workspace.yaml
  -s, --single       Force single-project mode (ignore workspace.yaml)
  -r, --remote HOST  SSH remote connection
  -h, --help         Show this help message

Note:
  npm update is NOT run automatically to avoid conflicts.
  Update manually when needed:
    npm update -g @anthropic-ai/claude-code @openai/codex

Modes:
  Single Project Mode (default)
    - 3-pane layout: Claude Code, Codex, yazi
    - Session name: <project-name>

  Multi-Project Mode (workspace)
    - Enabled when ~/.config/tproj/workspace.yaml exists
    - Multiple columns, each with Claude Code + Codex
    - Session name: tproj-workspace
    - Use -s to force single mode

Workspace Configuration:
  File: ~/.config/tproj/workspace.yaml

  Global sections:
    launch.claude.args
    launch.codex.args
    tmux_ui.pane_border
    tmux_ui.pane_title
    tmux_ui.window_text

  Example:
    projects:
      - /path/to/project1
      - /path/to/project2
      - /path/to/project3

Key Bindings:
  Prefix + y    Toggle yazi (in active column)
  Prefix + arrows    Switch between panes/columns

Examples:
  tproj                   # Auto-detect mode (workspace or single)
  tproj --add             # Add one column in running tproj-workspace
  tproj -s                # Force single mode
  tproj -r macmini        # SSH remote connection (single mode only)

For more information, see: README.md
EOF
}

NO_UPDATE=true  # npm update は手動で実行してください
REMOTE_HOST=""
FORCE_SINGLE_MODE=false
ADD_MODE=false
ADD_ALIAS=""
CHECK_MODE=false
SYNC_UI_MODE=false
REPAIR_MODE=false
MAX_COLUMNS=""  # 空 = 制限なし
NO_GUI=false

declare -a GLOBAL_CLAUDE_ARGS
declare -a GLOBAL_CODEX_ARGS

TMUX_UI_PANE_BORDER_ACTIVE_FG="colour51"
TMUX_UI_PANE_BORDER_ACTIVE_BOLD="true"
TMUX_UI_PANE_BORDER_INACTIVE_FG="colour248"
TMUX_UI_PANE_TITLE_ACTIVE_PREFIX="▶▶ "
TMUX_UI_PANE_TITLE_ACTIVE_FG="colour231"
TMUX_UI_PANE_TITLE_ACTIVE_BG="colour24"
TMUX_UI_PANE_TITLE_INACTIVE_PREFIX="  "
TMUX_UI_PANE_TITLE_INACTIVE_FG="colour255"
TMUX_UI_PANE_TITLE_INACTIVE_BG="colour238"
TMUX_UI_PANE_BORDER_PREV1_FG="colour211"
TMUX_UI_PANE_BORDER_PREV2_FG="colour175"
TMUX_UI_PANE_TITLE_PREV1_FG="colour211"
TMUX_UI_PANE_TITLE_PREV1_BG="colour237"
TMUX_UI_PANE_TITLE_PREV2_FG="colour175"
TMUX_UI_PANE_TITLE_PREV2_BG="colour237"
TMUX_UI_PANE_BORDER_PREV3_FG="colour139"
TMUX_UI_PANE_TITLE_PREV3_FG="colour139"
TMUX_UI_PANE_TITLE_PREV3_BG="colour237"
TMUX_UI_WINDOW_TEXT_ACTIVE_FG="colour231"
TMUX_UI_WINDOW_TEXT_ACTIVE_BG="terminal"
TMUX_UI_WINDOW_TEXT_ACTIVE_BOLD="true"
TMUX_UI_WINDOW_TEXT_INACTIVE_FG="colour250"
TMUX_UI_WINDOW_TEXT_INACTIVE_BG="terminal"

# --- init subcommand ---
if [[ "${1:-}" == "init" ]]; then
  echo "tproj init - interactive setup wizard"
  echo ""

  # 1. Dependency check
  echo "=== Checking dependencies ==="
  MISSING_BREW=()
  MISSING_INFO=()
  for dep in tmux jq yq bat yazi; do
    if command -v "$dep" >/dev/null 2>&1; then
      printf "  %-16s %s\n" "$dep" "OK ($(command -v "$dep"))"
    else
      printf "  %-16s %s\n" "$dep" "MISSING"
      MISSING_BREW+=("$dep")
    fi
  done
  for dep in claude codex; do
    if command -v "$dep" >/dev/null 2>&1; then
      printf "  %-16s %s\n" "$dep" "OK"
    else
      printf "  %-16s %s\n" "$dep" "MISSING"
      MISSING_INFO+=("$dep")
    fi
  done
  echo ""

  if [[ ${#MISSING_BREW[@]} -gt 0 ]]; then
    echo "Install missing brew packages: ${MISSING_BREW[*]}"
    printf "  brew install %s\n" "${MISSING_BREW[*]}"
    printf "Run now? [Y/n] "
    read -r answer
    if [[ "${answer:-Y}" =~ ^[Yy]$ ]]; then
      brew install "${MISSING_BREW[@]}"
    fi
    echo ""
  fi

  if [[ ${#MISSING_INFO[@]} -gt 0 ]]; then
    echo "Missing AI tools (install manually):"
    for dep in "${MISSING_INFO[@]}"; do
      case "$dep" in
        claude) echo "  npm install -g @anthropic-ai/claude-code" ;;
        codex)  echo "  npm install -g @openai/codex" ;;
      esac
    done
    echo ""
  fi

  # 2. workspace.yaml
  WORKSPACE_DIR="$HOME/.config/tproj"
  WS_FILE="$WORKSPACE_DIR/workspace.yaml"
  echo "=== Workspace configuration ==="
  if [[ -f "$WS_FILE" ]]; then
    echo "  workspace.yaml already exists: $WS_FILE"
  else
    echo "  No workspace.yaml found."
    printf "  Enter your first project path: "
    read -r proj_path
    if [[ -n "$proj_path" && -d "$proj_path" ]]; then
      proj_name="$(basename "$proj_path")"
      printf "  Alias (short name) [%s]: " "$proj_name"
      read -r proj_alias
      proj_alias="${proj_alias:-$proj_name}"

      mkdir -p "$WORKSPACE_DIR"
      cat > "$WS_FILE" <<WSEOF
projects:
  - path: '${proj_path}'
    alias: '${proj_alias}'
WSEOF
      echo "  Created: $WS_FILE"
    else
      echo "  Skipped (invalid path or empty)."
    fi
  fi
  echo ""

  # 3. Claude Code hooks
  echo "=== Claude Code hooks ==="
  SETTINGS_FILE="$HOME/.claude/settings.json"
  if [[ -f "$SETTINGS_FILE" ]]; then
    if grep -q "project-bootstrap" "$SETTINGS_FILE" 2>/dev/null; then
      echo "  SessionStart hook: already configured"
    else
      echo "  SessionStart hook: NOT configured"
      echo "  This hook auto-generates persona for each project."
      printf "  Add SessionStart hook? [Y/n] "
      read -r answer
      if [[ "${answer:-Y}" =~ ^[Yy]$ ]]; then
        # Use jq to add hook to existing settings
        if command -v jq >/dev/null 2>&1; then
          NEW_HOOK='{"hooks":[{"type":"command","command":"$HOME/bin/project-bootstrap"}]}'
          jq --argjson hook "$NEW_HOOK" '
            .hooks.SessionStart = (.hooks.SessionStart // []) + [$hook]
          ' "$SETTINGS_FILE" > "${SETTINGS_FILE}.tmp" && mv "${SETTINGS_FILE}.tmp" "$SETTINGS_FILE"
          echo "  Added SessionStart hook."
        else
          echo "  jq not available, please add manually to $SETTINGS_FILE"
        fi
      fi
    fi
  else
    echo "  $SETTINGS_FILE not found. Install Claude Code first."
  fi
  echo ""

  # 4. PATH check
  echo "=== PATH ==="
  if echo "$PATH" | grep -q "$HOME/bin"; then
    echo "  ~/bin is in PATH: OK"
  else
    echo "  ~/bin is NOT in PATH"
    echo "  Add to your shell profile:"
    echo '    export PATH="$HOME/bin:$PATH"'
  fi
  echo ""

  echo "=== Setup complete ==="
  echo "Next steps:"
  echo "  tproj --check    # verify everything"
  echo "  tproj            # launch workspace"
  exit 0
fi

# stop/kill サブコマンド
if [[ "${1:-}" == "stop" ]]; then
  stop_session
  exit 0
fi
if [[ "${1:-}" == "kill" ]]; then
  kill_session
  exit 0
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) show_help; exit 0 ;;
    --check) CHECK_MODE=true; shift ;;
    --sync-ui) SYNC_UI_MODE=true; shift ;;
    --repair) REPAIR_MODE=true; shift ;;
    --add)
      ADD_MODE=true; shift
      if [[ $# -gt 0 && "$1" != -* ]]; then
        ADD_ALIAS="$1"; shift
      fi
      ;;
    --no-gui) NO_GUI=true; shift ;;
    -c|--columns)
      [[ -z "${2:-}" ]] && { echo "Error: -c requires a number" >&2; exit 1; }
      MAX_COLUMNS="$2"; shift 2 ;;
    -n|--no-update) NO_UPDATE=true; shift ;;
    -s|--single) FORCE_SINGLE_MODE=true; shift ;;
    -r|--remote)
      [[ -z "${2:-}" ]] && { echo "Error: -r requires a hostname" >&2; exit 1; }
      REMOTE_HOST="$2"; shift 2 ;;
    -*) echo "Unknown option: $1" >&2; echo "Run 'tproj --help' for usage" >&2; exit 1 ;;
    *) echo "Unexpected argument: $1" >&2; echo "Run 'tproj --help' for usage" >&2; exit 1 ;;
  esac
done

# セッション存在チェック関数
has_claude_session() {
  local abs_path="$1"
  local encoded="${abs_path//\//-}"
  local proj_dir="$HOME/.claude/projects/$encoded"
  [[ -f "$proj_dir/sessions-index.json" ]] || ls "$proj_dir"/*.jsonl &>/dev/null
}

# ペインラベル生成
# 形式: {name}.{cc|cdx} {persona} / {name}.{cc|cdx}@{host} {persona}
# 引数: project_type project_host project_path tool_kind [alias]
build_pane_label() {
  local project_type="$1"
  local project_host="$2"
  local project_path="$3"
  local tool_kind="$4"
  local project_alias="${5:-}"

  local suffix="cc"
  [[ "$tool_kind" == "Codex" ]] && suffix="cdx"

  local project_name
  if [[ -n "$project_alias" ]]; then
    project_name="$project_alias"
  else
    project_name="$(basename "$project_path" 2>/dev/null || true)"
    [[ -z "$project_name" || "$project_name" == "." || "$project_name" == "/" ]] && project_name="unknown"
  fi

  local host_suffix=""
  if [[ "$project_type" == "remote" && -n "$project_host" ]]; then
    host_suffix="@${project_host}"
  fi

  local persona=""
  if [[ -n "${TPROJ_LABEL_HOOK:-}" ]] && command -v "$TPROJ_LABEL_HOOK" &>/dev/null; then
    persona="$("$TPROJ_LABEL_HOOK" --label "$project_path" "$suffix" 2>/dev/null || true)"
  fi

  echo "${project_name}.${suffix}${host_suffix} ${persona}"
}

shell_join_tokens() {
  local -a tokens=("$@")
  local joined=""
  local token
  for token in "${tokens[@]}"; do
    joined+="$(printf '%q' "$token") "
  done
  printf '%s' "${joined% }"
}

build_claude_continue_shell() {
  local -a tokens=(claude --continue)
  tokens+=("${GLOBAL_CLAUDE_ARGS[@]}")
  shell_join_tokens "${tokens[@]}"
}

build_claude_fresh_shell() {
  local -a tokens=(claude)
  tokens+=("${GLOBAL_CLAUDE_ARGS[@]}")
  shell_join_tokens "${tokens[@]}"
}

build_claude_launch_shell() {
  local project_path="$1"
  local project_type="$2"
  local include_cd="${3:-true}"
  local command=""

  if [[ "$project_type" == "remote" ]]; then
    command="$(build_claude_continue_shell) || $(build_claude_fresh_shell)"
  else
    if has_claude_session "$project_path"; then
      command="$(build_claude_continue_shell)"
    else
      command="$(build_claude_fresh_shell)"
    fi
    if [[ "$include_cd" == "true" ]]; then
      command="cd $(printf '%q' "$project_path") && $command"
    fi
  fi

  # Append postmortem forensics on abnormal exit
  command="$command; tproj-postmortem \$? claude"

  printf '%s' "$command"
}

build_codex_launch_shell() {
  local project_path="$1"
  local project_type="$2"
  local include_cd="${3:-true}"
  local -a tokens=(codex resume --last -s danger-full-access -a never --search)
  tokens+=("${GLOBAL_CODEX_ARGS[@]}")

  local command
  command="$(shell_join_tokens "${tokens[@]}")"
  if [[ "$project_type" != "remote" && "$include_cd" == "true" ]]; then
    command="cd $(printf '%q' "$project_path") && $command"
  fi

  # Append postmortem forensics on abnormal exit
  command="$command; tproj-postmortem \$? codex"

  printf '%s' "$command"
}

with_claude_update_prefix() {
  local command="$1"
  local no_update_mode="${2:-$NO_UPDATE}"
  if [[ "$no_update_mode" == "true" ]]; then
    printf '%s' "$command"
    return 0
  fi
  printf 'npm update -g @anthropic-ai/claude-code; hash -r; %s' "$command"
}

with_codex_update_prefix() {
  local command="$1"
  local no_update_mode="${2:-$NO_UPDATE}"
  if [[ "$no_update_mode" == "true" ]]; then
    printf '%s' "$command"
    return 0
  fi

  local sign_codex_cmd
  sign_codex_cmd="$(quoted_runtime_bin_path "sign-codex")"
  [[ -z "$sign_codex_cmd" ]] && sign_codex_cmd="sign-codex"
  printf 'npm update -g @openai/codex; %s; hash -r; %s' "$sign_codex_cmd" "$command"
}

# @tproj セッション一覧を取得（共通ヘルパー）
find_tproj_sessions() {
  tmux list-sessions -F '#{session_name}:#{@tproj}' 2>/dev/null \
    | grep ':true$' | cut -d: -f1
}

# tmux レイアウト変更を直列化する共有ロック (PID-based lockfile)
TPROJ_LAYOUT_LOCKFILE="/tmp/tproj-layout.lock"
TPROJ_LAYOUT_LOCK_HELD=false

acquire_layout_lock() {
  local timeout="${TPROJ_LOCK_TIMEOUT:-10}"
  local lockfile="$TPROJ_LAYOUT_LOCKFILE"
  local i=0
  while true; do
    # Try atomic create (noclobber = O_EXCL)
    if (set -C; echo $$ > "$lockfile") 2>/dev/null; then
      TPROJ_LAYOUT_LOCK_HELD=true
      return 0
    fi
    # Lock exists - check if holder is still alive
    local holder_pid
    holder_pid=$(cat "$lockfile" 2>/dev/null) || true
    if [[ -n "$holder_pid" ]] && ! kill -0 "$holder_pid" 2>/dev/null; then
      # Stale lock from dead process - remove and retry immediately
      rm -f "$lockfile"
      continue
    fi
    sleep 0.5
    i=$((i + 1))
    if [[ $i -ge $((timeout * 2)) ]]; then
      return 1
    fi
  done
}

release_layout_lock() {
  if [[ "$TPROJ_LAYOUT_LOCK_HELD" == "true" ]]; then
    rm -f "$TPROJ_LAYOUT_LOCKFILE"
    TPROJ_LAYOUT_LOCK_HELD=false
  fi
}

trap 'release_layout_lock' EXIT INT TERM

# Collect all descendant PIDs of given PIDs (BFS via pgrep -P)
collect_descendant_pids() {
  local queue=("$@")
  local all=()
  while [[ ${#queue[@]} -gt 0 ]]; do
    local cur="${queue[0]}"
    queue=("${queue[@]:1}")
    local ch
    ch=$(pgrep -P "$cur" 2>/dev/null) || true
    while IFS= read -r c; do
      [[ -n "$c" ]] && all+=("$c") && queue+=("$c")
    done <<< "$ch"
  done
  printf '%s\n' "${all[@]}"
}

# Collect descendant PIDs from all panes of given tproj sessions
collect_session_descendants() {
  local sessions="$1"
  local pane_pids_arr=()
  while IFS= read -r sess; do
    [[ -z "$sess" ]] && continue
    local pp
    pp=$(tmux list-panes -s -t "$sess" -F '#{pane_pid}' 2>/dev/null) || continue
    while IFS= read -r p; do
      [[ -n "$p" ]] && pane_pids_arr+=("$p")
    done <<< "$pp"
  done <<< "$sessions"
  [[ ${#pane_pids_arr[@]} -eq 0 ]] && return 0
  collect_descendant_pids "${pane_pids_arr[@]}"
}

# PID file for GUI process coordination (shared with dev-app.sh)
TPROJ_GUI_PIDFILE="${TMPDIR:-/tmp}/tproj-gui.pid"

# GUI 起動ターゲット選択
# 優先順位:
#   1) TPROJ_GUI_APP_PATH 環境変数（明示的オーバーライド）
#   2) gui.app_path in workspace.yaml（yaml で指定した場合）
#   3) debug バイナリ auto-detect (.build/.../debug/tproj)
_find_gui_target() {
  local p gui_bin

  # (1) 環境変数による明示的オーバーライド
  if [[ -n "${TPROJ_GUI_APP_PATH:-}" && -x "${TPROJ_GUI_APP_PATH}" ]]; then
    echo "$TPROJ_GUI_APP_PATH"
    return 0
  fi

  # (2) debug バイナリ（enabled + disabled 全プロジェクト + root を検索）
  for p in "${PROJECT_PATHS[@]}" "${CATALOG_PATHS[@]}" "$root"; do
    gui_bin="$p/apps/tproj/.build/arm64-apple-macosx/debug/tproj"
    [[ -x "$gui_bin" ]] && { echo "$gui_bin"; return 0; }
  done

  # (3) /Applications/tproj.app (Homebrew cask install)
  local app_bin="/Applications/tproj.app/Contents/MacOS/tproj"
  if [[ -x "$app_bin" ]]; then
    echo "$app_bin"
    return 0
  fi

  # (4) dist release bundle in tproj repo
  for p in "${PROJECT_PATHS[@]}" "${CATALOG_PATHS[@]}" "$root"; do
    gui_bin="$p/apps/tproj/dist/tproj.app/Contents/MacOS/tproj"
    [[ -x "$gui_bin" ]] && { echo "$gui_bin"; return 0; }
  done

  echo "tproj: warning: GUI app not found (set TPROJ_GUI_APP_PATH or brew install --cask tproj)" >&2
  return 1
}

# 全 GUI プロセスを確実に停止
_tproj_gui_kill_all() {
  # PID file で正確に殺す
  if [[ -f "$TPROJ_GUI_PIDFILE" ]]; then
    kill "$(<"$TPROJ_GUI_PIDFILE")" 2>/dev/null || true
    rm -f "$TPROJ_GUI_PIDFILE"
  fi
  # パターンで残党掃討
  pkill -f 'apps/tproj/dist/tproj.app/Contents/MacOS/tproj|\.build/.*/debug/tproj|/Applications/tproj.app/Contents/MacOS/tproj|tproj-gui' 2>/dev/null || true
  sleep 0.3
}

# TprojApp GUI を起動（kill-then-launch 方式）
launch_tproj_gui() {
  [[ "$NO_GUI" == "true" ]] && return 0

  local gui_path
  gui_path="$(_find_gui_target)" || return 0
  [[ -z "$gui_path" ]] && return 0

  # PID file あり && PID 生存 && 同じバイナリ → 既に正しいのが動いてる
  if [[ -f "$TPROJ_GUI_PIDFILE" ]]; then
    local existing_pid
    existing_pid="$(<"$TPROJ_GUI_PIDFILE")"
    if kill -0 "$existing_pid" 2>/dev/null; then
      local existing_args
      existing_args="$(ps -p "$existing_pid" -o args= 2>/dev/null || true)"
      if [[ "$existing_args" == "$gui_path" ]]; then
        return 0
      fi
    fi
  fi

  # 全プロセス停止してから起動
  _tproj_gui_kill_all

  "$gui_path" &
  disown
  echo "$!" > "$TPROJ_GUI_PIDFILE"
}

# レイアウト確定後フック（private 拡張用）
# TPROJ_AFTER_LAYOUT_HOOK は実行可能コマンド/パスを指定する。
# 未設定時は runtime bin か sibling repo の tproj-pane-bg を自動検出する。
resolve_after_layout_hook_path() {
  local hook_cmd="${TPROJ_AFTER_LAYOUT_HOOK:-}"
  local resolved=""
  local workspace_parent=""
  local sibling_path=""

  if [[ -n "$hook_cmd" ]]; then
    if command -v "$hook_cmd" >/dev/null 2>&1; then
      command -v "$hook_cmd"
      return 0
    fi
    if [[ -x "$hook_cmd" ]]; then
      printf '%s\n' "$hook_cmd"
      return 0
    fi
    echo "Warning: TPROJ_AFTER_LAYOUT_HOOK not found: $hook_cmd" >&2
    return 1
  fi

  resolved="$(runtime_bin_path "tproj-pane-bg" 2>/dev/null || true)"
  if [[ -n "$resolved" ]]; then
    printf '%s\n' "$resolved"
    return 0
  fi

  workspace_parent="$(cd "$SCRIPT_DIR/../.." && pwd)"
  sibling_path="${workspace_parent}/tproj-ext/bin/tproj-pane-bg"
  if [[ -x "$sibling_path" ]]; then
    printf '%s\n' "$sibling_path"
    return 0
  fi

  return 1
}

# 起動フローをブロックしないよう非同期で起動し、失敗しても続行する。
prime_after_layout_manifest() {
  local session_name="$1"
  local hook_path=""
  local log_file="/tmp/tproj-after-layout-${session_name}.log"

  hook_path="$(resolve_after_layout_hook_path 2>/dev/null || true)"
  [[ -z "$hook_path" ]] && return 0

  "$hook_path" sync --session "$session_name" --fast >>"$log_file" 2>&1 || true
}

run_after_layout_hook() {
  local session_name="$1"
  local mode="$2"
  local window_name="${3:-dev}"
  local project_root="${4:-}"
  local remote_host="${5:-}"
  local hook_path=""
  local log_file="/tmp/tproj-after-layout-${session_name}.log"

  hook_path="$(resolve_after_layout_hook_path 2>/dev/null || true)"
  [[ -z "$hook_path" ]] && return 0

  local -a hook_args
  hook_args=("$hook_path" --session "$session_name" --window "$window_name" --mode "$mode")
  [[ -n "$project_root" ]] && hook_args+=(--root "$project_root")
  [[ -n "$remote_host" ]] && hook_args+=(--remote-host "$remote_host")

  (
    "${hook_args[@]}"
  ) >>"$log_file" 2>&1 &!

  return 0
}

# --- Persona priming + hot-swap ---
# Background: generate persona files, then hot-swap pane titles and trigger background image.
# Does NOT block the startup flow.
# Usage: prime_and_swap <session> <mode> <window> [args for run_after_layout_hook...]
prime_and_swap() {
  local session_name="$1"; shift
  local after_layout_mode="$1"; shift
  local after_layout_window="$1"; shift
  # Remaining args: project_root, remote_host (for single mode)
  local after_layout_root="${1:-}"
  local after_layout_remote="${2:-}"

  local persona_bin="${TPROJ_LABEL_HOOK:-}"
  [[ -z "$persona_bin" ]] && persona_bin="$(runtime_bin_path "project-bootstrap" 2>/dev/null || true)"
  [[ -z "$persona_bin" ]] && persona_bin="$(runtime_bin_path "cc-persona" 2>/dev/null || true)"
  [[ -z "$persona_bin" ]] && return 0

  # Collect project paths + types + aliases from pane tags
  local -a pane_entries
  local pane_id role project alias
  while IFS=$'\t' read -r pane_id role project alias; do
    [[ -z "$role" || "$role" == "(null)" ]] && continue
    # Single mode may not have @project set — fall back to after_layout_root
    [[ -z "$project" || "$project" == "(null)" ]] && project="$after_layout_root"
    [[ -z "$project" ]] && continue
    pane_entries+=("${pane_id}|${role}|${project}|${alias}")
  done < <(tmux list-panes -t "${session_name}:${after_layout_window}" \
    -F '#{pane_id}\t#{@role}\t#{@project}\t#{@alias}' 2>/dev/null || true)

  [[ ${#pane_entries[@]} -eq 0 ]] && return 0

  # 1. Run project-bootstrap --prime for each unique project (parallel)
  local -a primed_list prime_pids
  local entry
  for entry in "${pane_entries[@]}"; do
    IFS='|' read -r pane_id role project alias <<< "$entry"
    # Skip if already primed
    local already=false
    local p
    for p in "${primed_list[@]}"; do
      [[ "$p" == "$project" ]] && { already=true; break; }
    done
    $already && continue
    primed_list+=("$project")
    local -a prime_args=("$persona_bin" --prime "$project")
    [[ -n "$alias" && "$alias" != "(null)" ]] && prime_args+=(--alias "$alias")
    "${prime_args[@]}" >/dev/null 2>&1 &
    prime_pids+=($!)
  done

  # Wait for all priming to complete
  local pid
  for pid in "${prime_pids[@]}"; do
    wait "$pid" 2>/dev/null || true
  done

  # 2. Hot-swap pane titles with persona labels
  for entry in "${pane_entries[@]}"; do
    IFS='|' read -r pane_id role project alias <<< "$entry"
    local tool_kind="CC"
    case "$role" in
      codex*) tool_kind="Codex" ;;
    esac
    local proj_type="local"
    local proj_host=""
    local new_title
    new_title="$(build_pane_label "$proj_type" "$proj_host" "$project" "$tool_kind" "$alias")"
    tmux select-pane -t "$pane_id" -T "$new_title" 2>/dev/null || true
  done

  # 3. Run after-layout hook (background images) — persona traits now available
  run_after_layout_hook "$session_name" "$after_layout_mode" "$after_layout_window" \
    "$after_layout_root" "$after_layout_remote"
}

# GUI アプリ終了（keep_alive=false の場合のみ）
stop_tproj_gui_if_needed() {
  local keep_alive="true"  # デフォルト
  local ws_config="$HOME/.config/tproj/workspace.yaml"

  if [[ -f "$ws_config" ]]; then
    keep_alive=$(yq -r '.gui.keep_alive // "true"' "$ws_config" 2>/dev/null || echo "true")
  fi

  if [[ "$keep_alive" != "true" ]]; then
    _tproj_gui_kill_all
  fi
}

# Kill orphaned MCP server processes (PPID=1 = reparented to launchd)
cleanup_orphaned_mcp() {
  local orphans
  orphans=$(ps -eo pid=,ppid=,command= 2>/dev/null | \
    awk '$2 == 1' | \
    grep -E '(context7-mcp|playwright-mcp|claude-in-chrome-mcp|@playwright/mcp|@upstash/context7)' | \
    awk '{print $1}') || true
  [[ -z "$orphans" ]] && return 0
  while IFS= read -r pid; do
    [[ -n "$pid" ]] && kill -TERM "$pid" 2>/dev/null || true
  done <<< "$orphans"
}

# Kill surviving descendant processes after session termination
# Phase 1: SIGTERM, Phase 2: wait 2s, Phase 3: SIGKILL survivors
kill_surviving_descendants() {
  local desc_pids="$1"
  [[ -z "$desc_pids" ]] && return 0
  # Phase 1: SIGTERM
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    kill -0 "$pid" 2>/dev/null && kill -TERM "$pid" 2>/dev/null || true
  done <<< "$desc_pids"
  # Phase 2: Wait for graceful shutdown
  sleep 2
  # Phase 3: SIGKILL survivors
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    if kill -0 "$pid" 2>/dev/null; then
      kill -9 "$pid" 2>/dev/null || true
    fi
  done <<< "$desc_pids"
}

# セッション即時終了（tmux kill-session のみ）
kill_session() {
  local sessions
  sessions=$(find_tproj_sessions) || true

  if [[ -z "$sessions" ]]; then
    echo "No active tproj session" >&2
    return 0
  fi

  # Signal watchdog to exit and unhook pane-died before killing sessions
  while IFS= read -r _s; do
    [[ -z "$_s" ]] && continue
    tmux set-environment -t "$_s" TPROJ_STOPPING 1 2>/dev/null || true
    tmux set-hook -u -t "$_s" pane-died 2>/dev/null || true
  done <<< "$sessions"

  # Collect descendant PIDs before killing (to clean up MCP servers)
  local desc_pids
  desc_pids=$(collect_session_descendants "$sessions") || true

  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    pkill -TERM -f "bin/team-watcher" 2>/dev/null || true
    pkill -TERM -f "bin/tproj-pane-watchdog" 2>/dev/null || true
    tmux kill-session -t "$session" 2>/dev/null || true
  done <<< "$sessions"

  # Kill surviving MCP server processes
  kill_surviving_descendants "$desc_pids"
  cleanup_orphaned_mcp

  rm -f /tmp/tproj-dead-agents
  stop_tproj_gui_if_needed
  echo "Session killed" >&2
}

# セッショングレースフル終了（CC/Codex に終了シグナル送信後 kill）
stop_session() {
  local sessions panes pane_info pane_id role waited

  sessions=$(find_tproj_sessions) || true

  if [[ -z "$sessions" ]]; then
    echo "No active tproj session" >&2
    return 0
  fi

  # Signal watchdog to exit and unhook pane-died before stopping sessions
  while IFS= read -r _s; do
    [[ -z "$_s" ]] && continue
    tmux set-environment -t "$_s" TPROJ_STOPPING 1 2>/dev/null || true
    tmux set-hook -u -t "$_s" pane-died 2>/dev/null || true
  done <<< "$sessions"
  pkill -TERM -f "bin/tproj-pane-watchdog" 2>/dev/null || true

  # Collect descendant PIDs before stopping (to clean up MCP servers)
  local desc_pids
  desc_pids=$(collect_session_descendants "$sessions") || true

  while IFS= read -r session; do
    [[ -z "$session" ]] && continue

    # 全ウィンドウのペイン一覧（dev + git）
    panes=$(tmux list-panes -s -t "$session" -F '#{pane_id}:#{@role}' 2>/dev/null) || continue

    # Phase 1: グレースフル終了シグナル
    while IFS= read -r pane_info; do
      [[ -z "$pane_info" ]] && continue
      pane_id="${pane_info%%:*}"
      role="${pane_info#*:}"

      case "$role" in
        claude|claude-p*)
          tmux send-keys -t "$pane_id" C-c 2>/dev/null || true
          ;;
        codex|codex-p*)
          tmux send-keys -t "$pane_id" C-c 2>/dev/null || true
          ;;
        yazi|yazi-p*)
          tmux send-keys -t "$pane_id" q 2>/dev/null || true
          ;;
        agent-*)
          tmux send-keys -t "$pane_id" C-c 2>/dev/null || true
          ;;
      esac
    done <<< "$panes"

    # Ctrl+C の効果を待つ
    sleep 0.3

    # ロール別終了コマンドを送信（CC=exit, Cdx/Agent=/exit）
    while IFS= read -r pane_info; do
      [[ -z "$pane_info" ]] && continue
      pane_id="${pane_info%%:*}"
      role="${pane_info#*:}"

      case "$role" in
        claude|claude-p*|terminal-p*)
          tmux send-keys -t "$pane_id" "exit" C-m 2>/dev/null || true
          ;;
        codex|codex-p*|agent-*)
          tmux send-keys -t "$pane_id" "/exit" C-m 2>/dev/null || true
          ;;
      esac
    done <<< "$panes"

    # Phase 2: グレースフル終了待機（最大3秒）
    waited=0
    while [[ $waited -lt 30 ]]; do
      if ! tmux has-session -t "$session" 2>/dev/null; then
        break
      fi
      sleep 0.1
      ((waited++)) || true
    done

    # team-watcher デーモンを停止
    pkill -TERM -f "bin/team-watcher" 2>/dev/null || true

    # Phase 3: 残存セッションを強制終了
    tmux kill-session -t "$session" 2>/dev/null || true
  done <<< "$sessions"

  # Kill surviving MCP server processes
  kill_surviving_descendants "$desc_pids"
  cleanup_orphaned_mcp

  # 一時ファイルのクリーンアップ
  rm -f /tmp/tproj-dead-agents

  stop_tproj_gui_if_needed
  echo "Session stopped" >&2
}

# 既存 tproj-workspace に右列を追加
# 引数なし: 現在のペインのプロジェクトを複製
# 引数あり: add_workspace_column <path> <type> <host> [alias]
add_workspace_column() {
  local explicit_path="${1:-}"
  local explicit_type="${2:-}"
  local explicit_host="${3:-}"
  local explicit_alias="${4:-}"
  local session="tproj-workspace"
  local src_pane src_project src_remote_host src_remote_path
  local src_type src_host src_path src_dir src_alias
  local parsed parsed_host parsed_path
  local max_col new_col
  local right_claude new_claude new_codex
  local claude_title codex_title claude_cmd

  acquire_layout_lock || {
    echo "Error: failed to acquire layout lock" >&2
    exit 1
  }

  tmux has-session -t "$session" 2>/dev/null || {
    echo "Error: $session is not running" >&2
    exit 1
  }

  tmux list-panes -t "$session:dev" >/dev/null 2>&1 || {
    echo "Error: $session:dev not found" >&2
    exit 1
  }

  if [[ -n "$explicit_path" ]]; then
    # エイリアスモード: 引数をそのまま使用
    src_type="$explicit_type"
    src_host="$explicit_host"
    src_path="$explicit_path"
    src_alias="${explicit_alias:-$(basename "$src_path")}"
    src_dir="$src_path"
    [[ "$src_type" == "remote" ]] && src_dir="/tmp"
  else
    # 現在のペインから取得（既存動作）
    src_pane="${TMUX_PANE:-}"
    [[ -z "$src_pane" ]] && src_pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
    [[ -z "$src_pane" ]] && {
      echo "Error: cannot detect current pane" >&2
      exit 1
    }

    src_project="$(tmux display-message -t "$src_pane" -p '#{@project}' 2>/dev/null || true)"
    src_remote_host="$(tmux display-message -t "$src_pane" -p '#{@remote_host}' 2>/dev/null || true)"
    src_remote_path="$(tmux display-message -t "$src_pane" -p '#{@remote_path}' 2>/dev/null || true)"
    src_alias="$(tmux display-message -t "$src_pane" -p '#{@alias}' 2>/dev/null || true)"

    if [[ "$src_project" == ssh://* ]]; then
      src_type="remote"
      parsed="${src_project#ssh://}"
      parsed_host="${parsed%%/*}"
      parsed_path="/${parsed#*/}"
      src_host="${src_remote_host:-$parsed_host}"
      src_path="${src_remote_path:-$parsed_path}"
      src_dir="/tmp"
      [[ -z "$src_host" || -z "$src_path" ]] && {
        echo "Error: failed to resolve remote host/path from current pane" >&2
        exit 1
      }
    else
      src_type="local"
      src_host=""
      src_path="$src_project"
      [[ -z "$src_path" || "$src_path" == "null" ]] && \
        src_path="$(tmux display-message -t "$src_pane" -p '#{pane_current_path}' 2>/dev/null || true)"
      [[ -z "$src_path" ]] && {
        echo "Error: failed to resolve local project path from current pane" >&2
        exit 1
      }
      src_dir="$src_path"
    fi
  fi

  max_col="$(tmux list-panes -t "$session:dev" -F '#{@column}' 2>/dev/null \
    | awk '/^[0-9]+$/ { if ($1>max) max=$1 } END { print max+0 }')"
  [[ -z "$max_col" || "$max_col" -lt 1 ]] && {
    echo "Error: no workspace columns found in $session:dev" >&2
    exit 1
  }
  new_col=$((max_col + 1))

  right_codex="$(tmux list-panes -t "$session:dev" -F '#{pane_id}:#{@role}' 2>/dev/null \
    | grep ":codex-p${max_col}$" | cut -d: -f1)"
  [[ -z "$right_codex" ]] && {
    echo "Error: rightmost codex pane (codex-p${max_col}) not found" >&2
    exit 1
  }

  new_codex="$(tmux split-window -fh -t "$right_codex" -c "$src_dir" -P -F '#{pane_id}')"
  new_claude="$(tmux split-window -v -t "$new_codex" -c "$src_dir" -l 70% -P -F '#{pane_id}')"
  sleep 0.3

  # src_alias フォールバック
  [[ -z "${src_alias:-}" ]] && src_alias="$(basename "$src_path")"

  tmux set-option -pt "$new_claude" @role "claude-p${new_col}"
  tmux set-option -pt "$new_codex" @role "codex-p${new_col}"
  tmux set-option -pt "$new_claude" @column "$new_col"
  tmux set-option -pt "$new_codex" @column "$new_col"
  tmux set-option -pt "$new_claude" @alias "$src_alias"
  tmux set-option -pt "$new_codex" @alias "$src_alias"

  # Keep pane alive if shell dies (watchdog will respawn)
  tmux set-option -pt "$new_claude" remain-on-exit on 2>/dev/null || true
  tmux set-option -pt "$new_codex" remain-on-exit on 2>/dev/null || true

  claude_title="$(build_pane_label "$src_type" "$src_host" "$src_path" "CC" "$src_alias")"
  codex_title="$(build_pane_label "$src_type" "$src_host" "$src_path" "Codex" "$src_alias")"
  tmux set-option -pt "$new_claude" allow-set-title off 2>/dev/null || true
  tmux set-option -pt "$new_codex" allow-set-title off 2>/dev/null || true
  tmux select-pane -t "$new_claude" -T "$claude_title" 2>/dev/null || true
  tmux select-pane -t "$new_codex" -T "$codex_title" 2>/dev/null || true

  if [[ "$src_type" == "remote" ]]; then
    tmux set-option -pt "$new_claude" @project "ssh://$src_host/$src_path"
    tmux set-option -pt "$new_codex" @project "ssh://$src_host/$src_path"
    tmux set-option -pt "$new_claude" @remote_host "$src_host"
    tmux set-option -pt "$new_codex" @remote_host "$src_host"
    tmux set-option -pt "$new_claude" @remote_path "$src_path"
    tmux set-option -pt "$new_codex" @remote_path "$src_path"
  else
    tmux set-option -pt "$new_claude" @project "$src_path"
    tmux set-option -pt "$new_codex" @project "$src_path"
  fi

  apply_tmux_ui_to_window "$session:dev"

  # 先にレイアウトを確定してから重いプロセスを起動し、Add直後の横揺れを抑える
  run_rebalance_workspace "$session"
  sleep 0.15

  # Add 時は npm update をスキップ（既存セッションで CC/Cdx は更新済み前提）
  NO_UPDATE=true

  local claude_cmd codex_cmd include_cd="true"
  [[ "$src_type" == "remote" ]] && include_cd="false"
  claude_cmd="$(build_claude_launch_shell "$src_path" "$src_type" "$include_cd")"
  codex_cmd="$(build_codex_launch_shell "$src_path" "$src_type" "$include_cd")"

  if [[ "$src_type" == "remote" ]]; then
    tmux send-keys -t "$new_claude" "ssh -t $src_host 'cd $src_path && exec \$SHELL -l'" C-m
    tmux send-keys -t "$new_codex" "ssh -t $src_host 'cd $src_path && exec \$SHELL -l'" C-m
    sleep 2

    tmux send-keys -t "$new_claude" "$(with_claude_update_prefix "$claude_cmd")" C-m
    sleep 0.2
    tmux send-keys -t "$new_codex" "$(with_codex_update_prefix "$codex_cmd")" C-m
  else
    tmux send-keys -t "$new_claude" "$(with_claude_update_prefix "$claude_cmd")" C-m
    sleep 0.2
    tmux send-keys -t "$new_codex" "$(with_codex_update_prefix "$codex_cmd")" C-m
  fi

  # Save launch commands for watchdog auto-restart
  tmux set-option -pt "$new_claude" @launch_cmd "$claude_cmd" 2>/dev/null || true
  tmux set-option -pt "$new_codex" @launch_cmd "$codex_cmd" 2>/dev/null || true

  tmux select-pane -t "$new_claude"
  tmux select-window -t "$session:dev"

  # Trigger pane-bg sync after tags are set (after-split-window fires too early)
  run_after_layout_hook "$session" "workspace" "dev"

  release_layout_lock
  echo "✅ Added workspace column $new_col: $src_path" >&2
}

require_workspace_yq() {
  if command -v yq &>/dev/null; then
    return 0
  fi

  echo "" >&2
  echo "❌ Error: yq is not installed (required for workspace.yaml config)" >&2
  echo "" >&2
  echo "Options:" >&2
  echo "  1. Install yq:    brew install yq" >&2
  echo "  2. Remove workspace.yaml to disable YAML config" >&2
  echo "  3. Use single mode without workspace.yaml" >&2
  exit 1
}

# --- Workspace JSON cache ---
# Convert YAML to JSON once; all subsequent reads use jq on WORKSPACE_JSON.
WORKSPACE_JSON=""

load_workspace_json() {
  [[ -n "$WORKSPACE_JSON" ]] && return 0
  [[ -f "$WORKSPACE_CONFIG" ]] || return 1
  require_workspace_yq
  WORKSPACE_JSON="$(yq -o json "$WORKSPACE_CONFIG" 2>/dev/null)" || {
    echo "Error: Failed to parse $WORKSPACE_CONFIG" >&2
    exit 1
  }
}

# Read a string value from cached JSON. Returns default if null/missing.
ws_string() {
  local query="$1" default_value="$2"
  local val
  val="$(echo "$WORKSPACE_JSON" | jq -r "$query // empty" 2>/dev/null)" || true
  printf '%s' "${val:-$default_value}"
}

# Read a bool value from cached JSON. Returns default if null/missing.
ws_bool() {
  local query="$1" default_value="$2"
  local val
  val="$(echo "$WORKSPACE_JSON" | jq -r "if $query == null then empty else $query end" 2>/dev/null)" || true
  printf '%s' "${val:-$default_value}"
}

# Read a string array from cached JSON into a named array variable.
ws_string_array() {
  local query="$1" target_name="$2"
  eval "$target_name=()"
  local val
  val="$(echo "$WORKSPACE_JSON" | jq -r "($query // [])[]" 2>/dev/null)" || true
  [[ -z "$val" ]] && return 0
  local item quoted_value
  while IFS= read -r item; do
    quoted_value="$(printf '%q' "$item")"
    eval "$target_name+=($quoted_value)"
  done <<< "$val"
}

parse_global_workspace_config() {
  load_workspace_json || return 0

  ws_string_array '.launch.claude.args' GLOBAL_CLAUDE_ARGS
  ws_string_array '.launch.codex.args' GLOBAL_CODEX_ARGS

  # GUI app path from workspace.yaml (env var takes precedence)
  local yaml_app_path
  yaml_app_path="$(ws_string '.gui.app_path' '')"
  if [[ -n "$yaml_app_path" && -z "${TPROJ_GUI_APP_PATH:-}" ]]; then
    TPROJ_GUI_APP_PATH="$yaml_app_path"
  fi

  # Batch-read all tmux_ui settings in a single jq call (TSV output)
  local ui_line
  ui_line="$(echo "$WORKSPACE_JSON" | jq -r '[
    (.tmux_ui.pane_border.active_fg // ""),
    (if .tmux_ui.pane_border.active_bold == null then "" else (.tmux_ui.pane_border.active_bold | tostring) end),
    (.tmux_ui.pane_border.inactive_fg // ""),
    (.tmux_ui.pane_border.prev1_fg // ""),
    (.tmux_ui.pane_border.prev2_fg // ""),
    (.tmux_ui.pane_border.prev3_fg // ""),
    (.tmux_ui.pane_title.active_prefix // ""),
    (.tmux_ui.pane_title.active_fg // ""),
    (.tmux_ui.pane_title.active_bg // ""),
    (.tmux_ui.pane_title.inactive_prefix // ""),
    (.tmux_ui.pane_title.inactive_fg // ""),
    (.tmux_ui.pane_title.inactive_bg // ""),
    (.tmux_ui.pane_title.prev1_fg // ""),
    (.tmux_ui.pane_title.prev1_bg // ""),
    (.tmux_ui.pane_title.prev2_fg // ""),
    (.tmux_ui.pane_title.prev2_bg // ""),
    (.tmux_ui.pane_title.prev3_fg // ""),
    (.tmux_ui.pane_title.prev3_bg // ""),
    (.tmux_ui.window_text.active_fg // ""),
    (.tmux_ui.window_text.active_bg // ""),
    (.tmux_ui.window_text.inactive_fg // ""),
    (.tmux_ui.window_text.inactive_bg // "")
  ] | join("\t")' 2>/dev/null)" || true

  if [[ -n "$ui_line" ]]; then
    local -a ui_fields
    IFS=$'\t' read -rA ui_fields <<< "$ui_line"
    [[ -n "${ui_fields[0]:-}" ]] && TMUX_UI_PANE_BORDER_ACTIVE_FG="${ui_fields[0]}"
    [[ -n "${ui_fields[1]:-}" ]] && TMUX_UI_PANE_BORDER_ACTIVE_BOLD="${ui_fields[1]}"
    [[ -n "${ui_fields[2]:-}" ]] && TMUX_UI_PANE_BORDER_INACTIVE_FG="${ui_fields[2]}"
    [[ -n "${ui_fields[3]:-}" ]] && TMUX_UI_PANE_BORDER_PREV1_FG="${ui_fields[3]}"
    [[ -n "${ui_fields[4]:-}" ]] && TMUX_UI_PANE_BORDER_PREV2_FG="${ui_fields[4]}"
    [[ -n "${ui_fields[5]:-}" ]] && TMUX_UI_PANE_BORDER_PREV3_FG="${ui_fields[5]}"
    [[ -n "${ui_fields[6]:-}" ]] && TMUX_UI_PANE_TITLE_ACTIVE_PREFIX="${ui_fields[6]}"
    [[ -n "${ui_fields[7]:-}" ]] && TMUX_UI_PANE_TITLE_ACTIVE_FG="${ui_fields[7]}"
    [[ -n "${ui_fields[8]:-}" ]] && TMUX_UI_PANE_TITLE_ACTIVE_BG="${ui_fields[8]}"
    [[ -n "${ui_fields[9]:-}" ]] && TMUX_UI_PANE_TITLE_INACTIVE_PREFIX="${ui_fields[9]}"
    [[ -n "${ui_fields[10]:-}" ]] && TMUX_UI_PANE_TITLE_INACTIVE_FG="${ui_fields[10]}"
    [[ -n "${ui_fields[11]:-}" ]] && TMUX_UI_PANE_TITLE_INACTIVE_BG="${ui_fields[11]}"
    [[ -n "${ui_fields[12]:-}" ]] && TMUX_UI_PANE_TITLE_PREV1_FG="${ui_fields[12]}"
    [[ -n "${ui_fields[13]:-}" ]] && TMUX_UI_PANE_TITLE_PREV1_BG="${ui_fields[13]}"
    [[ -n "${ui_fields[14]:-}" ]] && TMUX_UI_PANE_TITLE_PREV2_FG="${ui_fields[14]}"
    [[ -n "${ui_fields[15]:-}" ]] && TMUX_UI_PANE_TITLE_PREV2_BG="${ui_fields[15]}"
    [[ -n "${ui_fields[16]:-}" ]] && TMUX_UI_PANE_TITLE_PREV3_FG="${ui_fields[16]}"
    [[ -n "${ui_fields[17]:-}" ]] && TMUX_UI_PANE_TITLE_PREV3_BG="${ui_fields[17]}"
    [[ -n "${ui_fields[18]:-}" ]] && TMUX_UI_WINDOW_TEXT_ACTIVE_FG="${ui_fields[18]}"
    [[ -n "${ui_fields[19]:-}" ]] && TMUX_UI_WINDOW_TEXT_ACTIVE_BG="${ui_fields[19]}"
    [[ -n "${ui_fields[20]:-}" ]] && TMUX_UI_WINDOW_TEXT_INACTIVE_FG="${ui_fields[20]}"
    [[ -n "${ui_fields[21]:-}" ]] && TMUX_UI_WINDOW_TEXT_INACTIVE_BG="${ui_fields[21]}"
  fi
}

render_tmux_pane_border_format() {
  local active_prefix_style="#[bg=${TMUX_UI_PANE_TITLE_ACTIVE_BG}]#[fg=${TMUX_UI_PANE_BORDER_ACTIVE_FG}]"
  local active_text_style="#[fg=${TMUX_UI_PANE_TITLE_ACTIVE_FG}]#[bold]"
  local inactive_style="#[bg=${TMUX_UI_PANE_TITLE_INACTIVE_BG}]#[fg=${TMUX_UI_PANE_TITLE_INACTIVE_FG}]"
  local prev1_prefix_style="#[bg=${TMUX_UI_PANE_TITLE_PREV1_BG}]#[fg=${TMUX_UI_PANE_BORDER_PREV1_FG}]"
  local prev1_text_style="#[fg=${TMUX_UI_PANE_TITLE_PREV1_FG}]"
  local prev2_style="#[bg=${TMUX_UI_PANE_TITLE_PREV2_BG}]#[fg=${TMUX_UI_PANE_TITLE_PREV2_FG}]"
  local prev3_style="#[bg=${TMUX_UI_PANE_TITLE_PREV3_BG}]#[fg=${TMUX_UI_PANE_TITLE_PREV3_FG}]"
  local ts_style="#[fg=colour243]"

  if [[ "$TMUX_UI_PANE_BORDER_ACTIVE_BOLD" == "true" ]]; then
    active_prefix_style="${active_prefix_style}#[bold]"
  fi

  # Timestamp suffix: show @last_focus_at for auto-focus events.
  # Manual focus changes must not create or refresh this timestamp.
  local ts_part="#{?#{@last_focus_at}, ${ts_style}#{@last_focus_at}#[default],}"

  # Active state
  local active_fmt="${active_prefix_style}${TMUX_UI_PANE_TITLE_ACTIVE_PREFIX}${active_text_style}#{pane_title}${ts_part}"

  # prev1 state
  local prev1_fmt="${prev1_prefix_style}${TMUX_UI_PANE_TITLE_ACTIVE_PREFIX}${prev1_text_style}#{pane_title}${ts_part}"

  # prev2 state
  local prev2_fmt="${prev2_style}${TMUX_UI_PANE_TITLE_INACTIVE_PREFIX}#{pane_title}${ts_part}"

  # prev3 state
  local prev3_fmt="${prev3_style}${TMUX_UI_PANE_TITLE_INACTIVE_PREFIX}#{pane_title}${ts_part}"

  # inactive state (default)
  local inactive_fmt="${inactive_style}${TMUX_UI_PANE_TITLE_INACTIVE_PREFIX}#{pane_title}${ts_part}"

  # Nested conditional: active -> prev1 -> prev2 -> prev3 -> inactive
  # #{?pane_active, ACTIVE, #{?#{==:#{@pane_rank},prev1}, PREV1, #{?#{==:#{@pane_rank},prev2}, PREV2, #{?#{==:#{@pane_rank},prev3}, PREV3, INACTIVE}}}}
  printf '#{?pane_active,%s,#{?#{==:#{@pane_rank},prev1},%s,#{?#{==:#{@pane_rank},prev2},%s,#{?#{==:#{@pane_rank},prev3},%s,%s}}}}#[default]' \
    "$active_fmt" \
    "$prev1_fmt" \
    "$prev2_fmt" \
    "$prev3_fmt" \
    "$inactive_fmt"
}

apply_tmux_ui_to_window() {
  local target="$1"
  local pane_border_format
  local active_border_style="fg=${TMUX_UI_PANE_BORDER_ACTIVE_FG}"
  local inactive_border_style="fg=${TMUX_UI_PANE_BORDER_INACTIVE_FG}"
  local window_style="fg=${TMUX_UI_WINDOW_TEXT_INACTIVE_FG},bg=${TMUX_UI_WINDOW_TEXT_INACTIVE_BG}"
  local window_active_style="fg=${TMUX_UI_WINDOW_TEXT_ACTIVE_FG},bg=${TMUX_UI_WINDOW_TEXT_ACTIVE_BG}"

  [[ "${TMUX_UI_WINDOW_TEXT_ACTIVE_BOLD:-}" == "true" ]] && window_active_style+=",bold"
  [[ "$TMUX_UI_PANE_BORDER_ACTIVE_BOLD" == "true" ]] && active_border_style+=",bold"
  pane_border_format="$(render_tmux_pane_border_format)"

  tmux set-option -w -t "$target" pane-border-status top >/dev/null 2>&1 || true
  tmux set-option -w -t "$target" pane-border-format "$pane_border_format" >/dev/null 2>&1 || true
  tmux set-option -w -t "$target" pane-border-style "$inactive_border_style" >/dev/null 2>&1 || true
  tmux set-option -w -t "$target" pane-active-border-style "$active_border_style" >/dev/null 2>&1 || true
  tmux set-option -w -t "$target" window-style "$window_style" >/dev/null 2>&1 || true
  tmux set-option -w -t "$target" window-active-style "$window_active_style" >/dev/null 2>&1 || true
}

install_pane_focus_hook() {
  local session="$1"
  local hook_path
  local direct_hook="$SCRIPT_DIR/tproj-pane-focus-hook"
  if [[ -x "$direct_hook" ]]; then
    hook_path="$(printf '%q' "$direct_hook")"
  else
    hook_path="$(quoted_runtime_bin_path "tproj-pane-focus-hook" 2>/dev/null || true)"
  fi
  [[ -z "$hook_path" ]] && return 0

  # Store color config in session env for the hook script
  tmux set-environment -t "$session" TPROJ_PREV1_BORDER_FG "$TMUX_UI_PANE_BORDER_PREV1_FG" 2>/dev/null || true
  tmux set-environment -t "$session" TPROJ_PREV2_BORDER_FG "$TMUX_UI_PANE_BORDER_PREV2_FG" 2>/dev/null || true
  tmux set-environment -t "$session" TPROJ_PREV3_BORDER_FG "$TMUX_UI_PANE_BORDER_PREV3_FG" 2>/dev/null || true

  # Install after-select-pane hook
  tmux set-hook -t "$session" after-select-pane \
    "run-shell '$hook_path #{session_name} #{pane_id}'" 2>/dev/null || true

  # Install pane-died hook: respawn CC/Cdx panes via respawn-guard (circuit breaker)
  # Only respawn if @role matches claude* or codex*; other panes are left alone.
  local respawn_guard="$HOME/bin/tproj-respawn-guard"
  [[ ! -x "$respawn_guard" ]] && respawn_guard="$SCRIPT_DIR/tproj-respawn-guard"
  tmux set-hook -t "$session" pane-died \
    "if-shell -F '#{m:claude*,#{@role}}' \
       'run-shell \"$respawn_guard #{session_name} #{pane_id} #{@role}\"' \
     'if-shell -F \"#{m:codex*,#{@role}}\" \
       \"run-shell \\\"$respawn_guard #{session_name} #{pane_id} #{@role}\\\"\"'" 2>/dev/null || true
}

repair_workspace_tags() {
  local session="$1"
  local repaired=0
  local pane_id role project alias column tool_kind
  local clean_project i label_kind proj_type proj_host parsed title

  while IFS=$'\t' read -r pane_id role project; do
    [[ -z "$role" || "$role" == "(null)" ]] && continue
    # role = "claude-p4" or "codex-p4"
    case "$role" in
      claude-p[0-9]*) tool_kind="claude"; column="${role#claude-p}" ;;
      codex-p[0-9]*)  tool_kind="codex";  column="${role#codex-p}" ;;
      *) continue ;;
    esac

    # Reverse-lookup alias from @project via CATALOG arrays
    alias=""
    clean_project="${project%/}"
    for ((i=0; i<${#CATALOG_PATHS[@]}; i++)); do
      if [[ "${CATALOG_PATHS[$i]%/}" == "$clean_project" ]]; then
        alias="${CATALOG_ALIASES[$i]}"
        break
      fi
    done
    [[ -z "$alias" ]] && alias="$(basename "$clean_project" 2>/dev/null || echo "unknown")"

    # Set tags
    tmux set-option -pt "$pane_id" @alias "$alias" 2>/dev/null || true
    tmux set-option -pt "$pane_id" @column "$column" 2>/dev/null || true

    # CC panes: prevent title override
    if [[ "$tool_kind" == "claude" ]]; then
      tmux set-option -pt "$pane_id" allow-set-title off 2>/dev/null || true
    fi

    # Rebuild pane_title
    label_kind="CC"
    [[ "$tool_kind" == "codex" ]] && label_kind="Codex"

    proj_type="local"; proj_host=""
    if [[ "$project" == ssh://* ]]; then
      proj_type="remote"
      parsed="${project#ssh://}"
      proj_host="${parsed%%/*}"
    fi

    title="$(build_pane_label "$proj_type" "$proj_host" "$clean_project" "$label_kind" "$alias")"
    tmux select-pane -t "$pane_id" -T "$title" 2>/dev/null || true

    ((repaired++)) || true
  done < <(tmux list-panes -t "$session:dev" -F "#{pane_id}	#{@role}	#{@project}" 2>/dev/null)

  echo "Repaired $repaired pane(s) in $session" >&2
}

sync_tmux_ui_for_live_sessions() {
  local -a sessions
  local session
  local window_name
  local synced=0

  sessions=("${(@f)$(find_tproj_sessions 2>/dev/null || true)}")
  if [[ ${#sessions[@]} -eq 0 ]]; then
    echo "No tproj sessions found to sync" >&2
    return 0
  fi

  for session in "${sessions[@]}"; do
    [[ -z "$session" ]] && continue
    while IFS= read -r window_name; do
      [[ -n "$window_name" ]] || continue
      apply_tmux_ui_to_window "${session}:${window_name}"
    done < <(tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null || true)
    install_pane_focus_hook "$session"
    synced=$((synced + 1))
  done

  echo "Synced UI for ${synced} tproj session(s)" >&2
}

print_global_workspace_config() {
  local claude_args="(none)"
  local codex_args="(none)"
  [[ ${#GLOBAL_CLAUDE_ARGS[@]} -gt 0 ]] && claude_args="$(shell_join_tokens "${GLOBAL_CLAUDE_ARGS[@]}")"
  [[ ${#GLOBAL_CODEX_ARGS[@]} -gt 0 ]] && codex_args="$(shell_join_tokens "${GLOBAL_CODEX_ARGS[@]}")"

  echo "" >&2
  echo "Global launch:" >&2
  echo "  claude args: $claude_args" >&2
  echo "  codex args:  $codex_args" >&2

  echo "" >&2
  echo "Resolved tmux_ui:" >&2
  echo "  pane_border: active_fg=${TMUX_UI_PANE_BORDER_ACTIVE_FG} active_bold=${TMUX_UI_PANE_BORDER_ACTIVE_BOLD} inactive_fg=${TMUX_UI_PANE_BORDER_INACTIVE_FG} prev1_fg=${TMUX_UI_PANE_BORDER_PREV1_FG} prev2_fg=${TMUX_UI_PANE_BORDER_PREV2_FG}" >&2
  echo "  pane_title:  active_prefix=$(printf '%q' "$TMUX_UI_PANE_TITLE_ACTIVE_PREFIX") active_fg=${TMUX_UI_PANE_TITLE_ACTIVE_FG} active_bg=${TMUX_UI_PANE_TITLE_ACTIVE_BG} inactive_prefix=$(printf '%q' "$TMUX_UI_PANE_TITLE_INACTIVE_PREFIX") inactive_fg=${TMUX_UI_PANE_TITLE_INACTIVE_FG} inactive_bg=${TMUX_UI_PANE_TITLE_INACTIVE_BG} prev1_fg=${TMUX_UI_PANE_TITLE_PREV1_FG} prev1_bg=${TMUX_UI_PANE_TITLE_PREV1_BG} prev2_fg=${TMUX_UI_PANE_TITLE_PREV2_FG} prev2_bg=${TMUX_UI_PANE_TITLE_PREV2_BG}" >&2
  echo "  window_text: active_fg=${TMUX_UI_WINDOW_TEXT_ACTIVE_FG} active_bg=${TMUX_UI_WINDOW_TEXT_ACTIVE_BG} inactive_fg=${TMUX_UI_WINDOW_TEXT_INACTIVE_FG} inactive_bg=${TMUX_UI_WINDOW_TEXT_INACTIVE_BG}" >&2
}

# === YAML パース & ワークスペースモード判定 ===
WORKSPACE_CONFIG="$HOME/.config/tproj/workspace.yaml"
WORKSPACE_MODE=false

# カタログ配列（全プロジェクト、--add エイリアス解決用）
declare -a CATALOG_PATHS
declare -a CATALOG_TYPES
declare -a CATALOG_HOSTS
declare -a CATALOG_ALIASES

# アクティブ配列（enabled=true のみ、起動レイアウト構築用）
declare -a PROJECT_PATHS
declare -a PROJECT_TYPES
declare -a PROJECT_HOSTS
declare -a PROJECT_ALIASES
declare -a PROJECT_CC_LAUNCH
declare -a PROJECT_CDX_LAUNCH

parse_workspace_yaml() {
  echo "tproj: loading workspace..." >&2

  load_workspace_json

  local num_projects
  num_projects=$(echo "$WORKSPACE_JSON" | jq '.projects | length' 2>/dev/null || echo "0")

  if [[ "$num_projects" -eq 0 ]]; then
    echo "" >&2
    echo "Error: workspace.yaml exists but contains no projects" >&2
    exit 1
  fi

  # Parse all projects in one jq call — outputs TSV lines
  # Fields: path \t type \t host \t alias \t enabled \t cc \t cdx
  local i proj_path proj_type proj_host proj_alias proj_enabled proj_cc proj_cdx
  while IFS=$'\t' read -r proj_path proj_type proj_host proj_alias proj_enabled proj_cc proj_cdx; do
    # Restore placeholders to empty
    [[ "$proj_path" == "_" ]] && proj_path=""
    [[ "$proj_host" == "_" ]] && proj_host=""

    # Handle simple format (string items)
    if [[ "$proj_type" == "_" || -z "$proj_type" ]]; then
      proj_type="local"
      proj_host=""
      proj_alias="$(basename "$proj_path")"
      proj_enabled="true"
      proj_cc="true"
      proj_cdx="true"
    fi

    # パスを展開（~ や環境変数）
    proj_path=$(eval echo "$proj_path")

    # 基本バリデーション
    if [[ "$proj_type" != "local" && "$proj_type" != "remote" ]]; then
      echo "  ⚠️  Skipping unknown type '$proj_type': $proj_path" >&2
      continue
    fi
    if [[ "$proj_type" == "remote" && -z "$proj_host" ]]; then
      echo "  ⚠️  Skipping remote project without host: $proj_path" >&2
      continue
    fi

    # カタログに追加（enabled 問わず、--add エイリアス解決用）
    CATALOG_PATHS+=("$proj_path")
    CATALOG_TYPES+=("$proj_type")
    CATALOG_HOSTS+=("$proj_host")
    CATALOG_ALIASES+=("$proj_alias")

    # アクティブ配列には enabled=true + 存在チェック済みのみ
    if [[ "$proj_enabled" != "true" ]]; then
      echo "  -- [disabled] $proj_path (alias: $proj_alias)" >&2
      continue
    fi

    if [[ "$proj_type" == "local" && ! -d "$proj_path" ]]; then
      echo "  ⚠️  Skipping non-existent: $proj_path (alias: $proj_alias)" >&2
      continue
    fi

    PROJECT_PATHS+=("$proj_path")
    PROJECT_TYPES+=("$proj_type")
    PROJECT_HOSTS+=("$proj_host")
    PROJECT_ALIASES+=("$proj_alias")
    PROJECT_CC_LAUNCH+=("$proj_cc")
    PROJECT_CDX_LAUNCH+=("$proj_cdx")

    if [[ "$proj_type" == "remote" ]]; then
      echo "  [remote@$proj_host] $proj_path (alias: $proj_alias)" >&2
    else
      echo "  [local] $proj_path (alias: $proj_alias)" >&2
    fi
  done < <(echo "$WORKSPACE_JSON" | jq -r '
    .projects[] |
    if type == "string" then
      . + "\t_\t_\t_\t_\t_\t_"
    else
      [
        (.path // "_"),
        (.type // "local"),
        (.host // "_"),
        (.alias // (.path | split("/") | last)),
        (if .enabled == false then "false" else "true" end),
        (if .cc == false then "false" else "true" end),
        (if .cdx == false then "false" else "true" end)
      ] | join("\t")
    end
  ' 2>/dev/null)
}

if [[ -f "$WORKSPACE_CONFIG" ]]; then
  parse_global_workspace_config
fi

if [[ "$SYNC_UI_MODE" == "true" ]]; then
  sync_tmux_ui_for_live_sessions
  exit 0
fi

if [[ "$REPAIR_MODE" == "true" ]]; then
  parse_workspace_yaml
  _repair_sessions=("${(@f)$(find_tproj_sessions 2>/dev/null || true)}")
  if [[ ${#_repair_sessions[@]} -eq 0 ]]; then
    echo "No tproj sessions found to repair" >&2
    exit 1
  fi
  for _rs in "${_repair_sessions[@]}"; do
    [[ -z "$_rs" ]] && continue
    repair_workspace_tags "$_rs"
    apply_tmux_ui_to_window "${_rs}:dev"
  done
  exit 0
fi

resolve_alias_to_project() {
  local target_alias="$1"
  local i
  for ((i=0; i<${#CATALOG_ALIASES[@]}; i++)); do
    if [[ "${CATALOG_ALIASES[$i]}" == "$target_alias" ]]; then
      RESOLVED_PATH="${CATALOG_PATHS[$i]}"
      RESOLVED_TYPE="${CATALOG_TYPES[$i]}"
      RESOLVED_HOST="${CATALOG_HOSTS[$i]}"
      return 0
    fi
  done
  return 1
}

# ワークスペースモード判定
if [[ "$FORCE_SINGLE_MODE" == "false" && -f "$WORKSPACE_CONFIG" ]]; then
  # --add <alias> / --check 時もパースが必要
  if [[ "$ADD_MODE" == "false" ]] || [[ -n "$ADD_ALIAS" ]] || [[ "$CHECK_MODE" == "true" ]]; then
    parse_workspace_yaml
  fi

  # -c N: 上位 N プロジェクトのみ使用
  if [[ -n "$MAX_COLUMNS" && "$MAX_COLUMNS" -gt 0 ]]; then
    if [[ ${#PROJECT_PATHS[@]} -gt $MAX_COLUMNS ]]; then
      PROJECT_PATHS=("${PROJECT_PATHS[@]:0:$MAX_COLUMNS}")
      PROJECT_TYPES=("${PROJECT_TYPES[@]:0:$MAX_COLUMNS}")
      PROJECT_HOSTS=("${PROJECT_HOSTS[@]:0:$MAX_COLUMNS}")
      PROJECT_ALIASES=("${PROJECT_ALIASES[@]:0:$MAX_COLUMNS}")
      echo "  columns limited to $MAX_COLUMNS (use --add to add more)" >&2
    fi
  fi

  if [[ "$ADD_MODE" == "false" && "$CHECK_MODE" == "false" ]]; then
    if [[ ${#PROJECT_PATHS[@]} -eq 0 ]]; then
      echo "" >&2
      echo "❌ Error: No valid project directories found" >&2
      echo "" >&2
      echo "Options:" >&2
      echo "  1. Fix project paths in $WORKSPACE_CONFIG" >&2
      echo "  2. Use single mode: tproj -s" >&2
      exit 1
    fi

    # プロジェクト数警告（10超）
    if [[ ${#PROJECT_PATHS[@]} -gt 10 ]]; then
      echo "⚠️  Warning: ${#PROJECT_PATHS[@]} projects configured (panes may be narrow)" >&2
      printf "Continue anyway? [y/N] " >&2
      read -r answer
      case "$answer" in
        [yY]) ;;
        *)
          echo "Tip: Use 'tproj -s' for single-project mode" >&2
          exit 0
          ;;
      esac
    fi

    WORKSPACE_MODE=true
  fi
fi

# リモートモード非対応チェック
if [[ "$WORKSPACE_MODE" == "true" && -n "$REMOTE_HOST" ]]; then
  echo "" >&2
  echo "❌ Error: Remote mode (-r) is not supported in workspace mode" >&2
  echo "" >&2
  echo "Options:" >&2
  echo "  1. Use single mode: tproj -s -r $REMOTE_HOST" >&2
  echo "  2. Remove -r option for local workspace mode" >&2
  exit 1
fi

if [[ "$CHECK_MODE" == "true" ]]; then
  CHECK_OK=true
  CHECK_WARN=false

  echo "=== Dependencies ===" >&2
  for dep in tmux jq yq bat yazi; do
    if command -v "$dep" >/dev/null 2>&1; then
      ver="$("$dep" --version 2>&1 | head -1 | tr -d '\n' || true)"
      printf "  %-16s %s\n" "$dep" "$ver" >&2
    else
      printf "  %-16s %s\n" "$dep" "MISSING" >&2
      CHECK_OK=false
    fi
  done
  for dep in claude codex; do
    if command -v "$dep" >/dev/null 2>&1; then
      ver="$("$dep" --version 2>&1 | head -1 | tr -d '\n' || true)"
      printf "  %-16s %s\n" "$dep" "$ver" >&2
    else
      printf "  %-16s %s\n" "$dep" "MISSING" >&2
      CHECK_OK=false
    fi
  done

  # Ghostty
  if pgrep -q -i ghostty 2>/dev/null; then
    printf "  %-16s %s\n" "Ghostty" "running" >&2
  else
    printf "  %-16s %s\n" "Ghostty" "not running (optional)" >&2
    CHECK_WARN=true
  fi
  echo "" >&2

  echo "=== Configuration ===" >&2
  # workspace.yaml
  if [[ -f "$WORKSPACE_CONFIG" ]]; then
    printf "  %-24s %s\n" "workspace.yaml" "OK" >&2
  else
    printf "  %-24s %s\n" "workspace.yaml" "MISSING" >&2
    CHECK_OK=false
  fi

  # settings.json hooks
  SETTINGS_FILE="$HOME/.claude/settings.json"
  if [[ -f "$SETTINGS_FILE" ]] && grep -q "project-bootstrap" "$SETTINGS_FILE" 2>/dev/null; then
    printf "  %-24s %s\n" "SessionStart hook" "OK" >&2
  else
    printf "  %-24s %s\n" "SessionStart hook" "NOT configured" >&2
    CHECK_WARN=true
  fi

  # PATH
  if echo "$PATH" | grep -q "$HOME/bin"; then
    printf "  %-24s %s\n" "~/bin in PATH" "OK" >&2
  else
    printf "  %-24s %s\n" "~/bin in PATH" "MISSING" >&2
    CHECK_OK=false
  fi

  # Optional: pane-bg
  if command -v tproj-pane-bg >/dev/null 2>&1; then
    printf "  %-24s %s\n" "tproj-pane-bg" "available" >&2
  else
    printf "  %-24s %s\n" "tproj-pane-bg" "not installed (optional)" >&2
  fi
  echo "" >&2

  # Workspace catalog
  if [[ -f "$WORKSPACE_CONFIG" ]]; then
    echo "=== Workspace ===" >&2
    for ((i=0; i<${#CATALOG_ALIASES[@]}; i++)); do
      local_type="${CATALOG_TYPES[$i]}"
      local_host="${CATALOG_HOSTS[$i]}"
      local_label="[local]"
      [[ "$local_type" == "remote" ]] && local_label="[remote@$local_host]"

      is_active=false
      for ((j=0; j<${#PROJECT_PATHS[@]}; j++)); do
        if [[ "${PROJECT_PATHS[$j]}" == "${CATALOG_PATHS[$i]}" ]]; then
          is_active=true
          break
        fi
      done

      if [[ "$is_active" == "true" ]]; then
        printf "  %-20s  %-12s  %s\n" "${CATALOG_ALIASES[$i]}" "$local_label" "${CATALOG_PATHS[$i]}" >&2
      else
        printf "  %-20s  %-12s  %s  (disabled)\n" "${CATALOG_ALIASES[$i]}" "$local_label" "${CATALOG_PATHS[$i]}" >&2
      fi
    done

    echo "" >&2
    echo "Active: ${#PROJECT_PATHS[@]} / Catalog: ${#CATALOG_ALIASES[@]}" >&2
    print_global_workspace_config
  fi

  echo "" >&2
  if [[ "$CHECK_OK" == "false" ]]; then
    echo "Some checks failed. Run 'tproj init' to fix." >&2
    exit 1
  elif [[ "$CHECK_WARN" == "true" ]]; then
    echo "All required checks passed (some optional items missing)." >&2
  else
    echo "All checks passed." >&2
  fi
  exit 0
fi

if [[ "$ADD_MODE" == "true" ]]; then
  [[ -n "$REMOTE_HOST" ]] && {
    echo "Error: --add cannot be used with -r/--remote" >&2
    exit 1
  }
  [[ "$FORCE_SINGLE_MODE" == "true" ]] && {
    echo "Error: --add cannot be used with -s/--single" >&2
    exit 1
  }
  if [[ -n "$ADD_ALIAS" ]]; then
    if resolve_alias_to_project "$ADD_ALIAS"; then
      add_workspace_column "$RESOLVED_PATH" "$RESOLVED_TYPE" "$RESOLVED_HOST" "$ADD_ALIAS"
    else
      echo "Error: Unknown alias '$ADD_ALIAS'" >&2
      echo "" >&2
      echo "Available:" >&2
      for ((i=0; i<${#CATALOG_ALIASES[@]}; i++)); do
        echo "  ${CATALOG_ALIASES[$i]}  ->  ${CATALOG_PATHS[$i]}" >&2
      done
      exit 1
    fi
  else
    add_workspace_column
  fi
  exit 0
fi

# === ワークスペースモード用関数 ===

# マルチ列レイアウト構築
# 引数: session paths[@] -- types[@] -- hosts[@] -- aliases[@]
create_workspace_layout() {
  local session="$1"
  shift

  # 配列を分離（paths, types, hosts, aliases）
  local -a paths types hosts aliases
  local num_projects=0

  # 最初の配列終了まで paths に格納
  while [[ $# -gt 0 && "$1" != "--" ]]; do
    paths+=("$1")
    ((num_projects++)) || true
    shift
  done
  shift  # "--" をスキップ

  # types を格納
  while [[ $# -gt 0 && "$1" != "--" ]]; do
    types+=("$1")
    shift
  done
  shift  # "--" をスキップ

  # hosts を格納
  while [[ $# -gt 0 && "$1" != "--" ]]; do
    hosts+=("$1")
    shift
  done
  shift  # "--" をスキップ

  # aliases を格納
  while [[ $# -gt 0 ]]; do
    aliases+=("$1")
    shift
  done

  # 全ての Claude ペインを先に横に作成
  declare -a claude_panes
  declare -a codex_panes
  local codex_title claude_title

  # 最初のプロジェクトのディレクトリ（ローカル優先、なければ /tmp）
  local first_dir="${paths[0]}"
  if [[ "${types[0]}" == "remote" ]]; then
    first_dir="/tmp"  # リモートの場合は一時的なディレクトリ
  fi
  tmux new-session -d -s "$session" -c "$first_dir" -n dev
  mark_session_runtime "$session"
  # 列削除時にも自動で横幅均等化
  local rebalance_cmd
  rebalance_cmd="$(quoted_runtime_bin_path "rebalance-workspace-columns")"
  if [[ -n "$rebalance_cmd" ]]; then
    tmux set-hook -t "$session" after-kill-pane "run-shell -b '$rebalance_cmd \"$session\"'"
  fi

  local first_codex=$(tmux list-panes -t "$session:dev" -F '#{pane_id}' | head -1)
  codex_panes[0]="$first_codex"

  # 追加の Codex ペインを横に作成
  local prev_codex="$first_codex"
  for ((i=2; i<=num_projects; i++)); do
    local proj_path="${paths[$((i-1))]}"
    local proj_type="${types[$((i-1))]}"
    local dir="$proj_path"
    [[ "$proj_type" == "remote" ]] && dir="/tmp"

    local new_codex=$(tmux split-window -h -t "$prev_codex" -c "$dir" -P -F '#{pane_id}')
    if [[ -z "$new_codex" ]]; then
      echo "Error: failed to create column $i (window may be too narrow for $num_projects columns)" >&2
      num_projects=$((i - 1))
      break
    fi
    codex_panes[$((i-1))]="$new_codex"
    prev_codex="$new_codex"

    # 均等化して次の分割に十分な幅を確保
    tmux select-layout -t "$session:dev" even-horizontal 2>/dev/null || true
  done

  sleep 0.3

  # 各 Codex の下に Claude を作成
  for ((i=1; i<=num_projects; i++)); do
    local proj_path="${paths[$((i-1))]}"
    local proj_type="${types[$((i-1))]}"
    local proj_host="${hosts[$((i-1))]}"
    local dir="$proj_path"
    [[ "$proj_type" == "remote" ]] && dir="/tmp"

    local codex_pane="${codex_panes[$((i-1))]}"
    local claude_pane=$(tmux split-window -v -t "$codex_pane" -c "$dir" -l 70% -P -F '#{pane_id}')
    claude_panes[$((i-1))]="$claude_pane"

    # タグ設定
    tmux set-option -pt "$codex_pane" @role "codex-p$i"
    tmux set-option -pt "$claude_pane" @role "claude-p$i"
    tmux set-option -pt "$codex_pane" @column "$i"
    tmux set-option -pt "$claude_pane" @column "$i"
    tmux set-option -pt "$codex_pane" @alias "${aliases[$((i-1))]}"
    tmux set-option -pt "$claude_pane" @alias "${aliases[$((i-1))]}"

    # Keep pane alive if shell dies (watchdog will respawn)
    tmux set-option -pt "$codex_pane" remain-on-exit on 2>/dev/null || true
    tmux set-option -pt "$claude_pane" remain-on-exit on 2>/dev/null || true

    # ペインタイトル設定
    codex_title="$(build_pane_label "$proj_type" "$proj_host" "$proj_path" "Codex" "${aliases[$((i-1))]}")"
    claude_title="$(build_pane_label "$proj_type" "$proj_host" "$proj_path" "CC" "${aliases[$((i-1))]}")"
    # CC/Codex が OSC タイトルで pane_title を上書きするため固定化
    tmux set-option -pt "$claude_pane" allow-set-title off 2>/dev/null || true
    tmux set-option -pt "$codex_pane" allow-set-title off 2>/dev/null || true
    tmux select-pane -t "$codex_pane" -T "$codex_title" 2>/dev/null || true
    tmux select-pane -t "$claude_pane" -T "$claude_title" 2>/dev/null || true

    # プロジェクト情報のタグ設定
    if [[ "$proj_type" == "remote" ]]; then
      tmux set-option -pt "$codex_pane" @project "ssh://$proj_host/$proj_path"
      tmux set-option -pt "$claude_pane" @project "ssh://$proj_host/$proj_path"
      tmux set-option -pt "$codex_pane" @remote_host "$proj_host"
      tmux set-option -pt "$claude_pane" @remote_host "$proj_host"
      tmux set-option -pt "$codex_pane" @remote_path "$proj_path"
      tmux set-option -pt "$claude_pane" @remote_path "$proj_path"
    else
      tmux set-option -pt "$codex_pane" @project "$proj_path"
      tmux set-option -pt "$claude_pane" @project "$proj_path"
    fi

    sleep 0.2
  done

  # 列幅を均等化
  local window_width=$(tmux display-message -t "$session:dev" -p '#{window_width}')
  local column_width=$((window_width / num_projects))

  for ((i=0; i<num_projects; i++)); do
    local codex_pane="${codex_panes[$i]}"
    [[ -z "$codex_pane" ]] && continue
    tmux resize-pane -t "$codex_pane" -x "$column_width" 2>/dev/null || true
  done

  apply_tmux_ui_to_window "$session:dev"

  # git window（最初のローカルプロジェクトのディレクトリ、なければ /tmp）
  local git_dir="/tmp"
  for ((i=0; i<num_projects; i++)); do
    if [[ "${types[$i]}" == "local" ]]; then
      git_dir="${paths[$i]}"
      break
    fi
  done
  tmux new-window -t "$session" -n git -c "$git_dir"
  apply_tmux_ui_to_window "$session:git"
  install_pane_focus_hook "$session"
}

# Codex ペインを起動（1列分）
# 引数: session no_update col_num path type host [cdx_launch]
start_codex_for_column() {
  local session="$1" no_update="$2" col="$3"
  local proj_path="$4" proj_type="$5" proj_host="$6" cdx_launch="${7:-true}"

  local codex_pane
  codex_pane=$(tmux list-panes -t "$session:dev" -F '#{pane_id}:#{@role}' \
    | grep ":codex-p${col}$" | cut -d: -f1)

  if [[ -z "$codex_pane" ]]; then
    echo "Error: Cannot find codex-p$col pane" >&2
    return 1
  fi

  local codex_cmd include_cd="true"
  [[ "$proj_type" == "remote" ]] && include_cd="false"
  codex_cmd="$(build_codex_launch_shell "$proj_path" "$proj_type" "$include_cd")"

  if [[ "$proj_type" == "remote" ]]; then
    tmux send-keys -t "$codex_pane" \
      "ssh -t $proj_host 'cd $proj_path && exec \$SHELL -l'" C-m
    sleep 2
    tmux send-keys -t "$codex_pane" \
      "$(with_codex_update_prefix "$codex_cmd" "$no_update")" C-m
  else
    # cdx: false のときはシェルで cd だけ
    if [[ "$cdx_launch" != "true" ]]; then
      tmux send-keys -t "$codex_pane" "cd \"$proj_path\"" C-m
      return
    fi
    tmux send-keys -t "$codex_pane" "$(with_codex_update_prefix "$codex_cmd" "$no_update")" C-m
  fi

  # Save launch command for watchdog auto-restart
  tmux set-option -pt "$codex_pane" @launch_cmd "$codex_cmd" 2>/dev/null || true
}

# Claude ペインを起動（1列分）
# 引数: session no_update col_num path type host [cc_launch]
start_claude_for_column() {
  local session="$1" no_update="$2" col="$3"
  local proj_path="$4" proj_type="$5" proj_host="$6" cc_launch="${7:-true}"

  local claude_pane
  claude_pane=$(tmux list-panes -t "$session:dev" -F '#{pane_id}:#{@role}' \
    | grep ":claude-p${col}$" | cut -d: -f1)

  if [[ -z "$claude_pane" ]]; then
    echo "Error: Cannot find claude-p$col pane" >&2
    return 1
  fi

  local claude_cmd include_cd="true"
  [[ "$proj_type" == "remote" ]] && include_cd="false"
  claude_cmd="$(build_claude_launch_shell "$proj_path" "$proj_type" "$include_cd")"

  if [[ "$proj_type" == "remote" ]]; then
    tmux send-keys -t "$claude_pane" \
      "ssh -t $proj_host 'cd $proj_path && exec \$SHELL -l'" C-m
    sleep 2
    tmux send-keys -t "$claude_pane" "$(with_claude_update_prefix "$claude_cmd" "$no_update")" C-m
  else
    # cc: false のときはシェルで cd だけ
    if [[ "$cc_launch" != "true" ]]; then
      tmux send-keys -t "$claude_pane" "cd \"$proj_path\"" C-m
      return
    fi
    tmux send-keys -t "$claude_pane" "$(with_claude_update_prefix "$claude_cmd" "$no_update")" C-m
  fi

  # Save launch command for watchdog auto-restart
  tmux set-option -pt "$claude_pane" @launch_cmd "$claude_cmd" 2>/dev/null || true
}

# プロジェクト別ツール起動（MCP フェーズ制御付き）
# 引数: session no_update paths[@] -- types[@] -- hosts[@] -- aliases[@] -- cc_launches[@] -- cdx_launches[@]
start_workspace_tools() {
  local session="$1"
  local no_update="$2"
  shift 2

  # 配列を分離（paths, types, hosts, aliases, cc_launches, cdx_launches）
  local -a paths types hosts aliases cc_launches cdx_launches
  local num_projects=0

  # 最初の配列終了まで paths に格納
  while [[ $# -gt 0 && "$1" != "--" ]]; do
    paths+=("$1")
    ((num_projects++)) || true
    shift
  done
  shift  # "--" をスキップ

  # types を格納
  while [[ $# -gt 0 && "$1" != "--" ]]; do
    types+=("$1")
    shift
  done
  shift  # "--" をスキップ

  # hosts を格納
  while [[ $# -gt 0 && "$1" != "--" ]]; do
    hosts+=("$1")
    shift
  done
  shift  # "--" をスキップ

  # aliases を格納
  while [[ $# -gt 0 && "$1" != "--" ]]; do
    aliases+=("$1")
    shift
  done

  # cc_launches を格納（存在する場合）
  if [[ $# -gt 0 ]]; then
    shift  # "--" をスキップ
    while [[ $# -gt 0 && "$1" != "--" ]]; do
      cc_launches+=("$1")
      shift
    done
  fi

  # cdx_launches を格納（存在する場合）
  if [[ $# -gt 0 ]]; then
    shift  # "--" をスキップ
    while [[ $# -gt 0 ]]; do
      cdx_launches+=("$1")
      shift
    done
  fi

  # Start panes per column (staggered to avoid memory spike from concurrent npm updates)
  for ((i=1; i<=num_projects; i++)); do
    local col_alias
    col_alias="$(basename "${paths[$((i-1))]}" 2>/dev/null || echo "project")"
    echo "tproj: starting ${col_alias} [$i/${num_projects}]..." >&2
    start_codex_for_column "$session" "$no_update" "$i" \
      "${paths[$((i-1))]}" "${types[$((i-1))]}" "${hosts[$((i-1))]}" "${cdx_launches[$((i-1))]:-true}"
    sleep 0.5
    start_claude_for_column "$session" "$no_update" "$i" \
      "${paths[$((i-1))]}" "${types[$((i-1))]}" "${hosts[$((i-1))]}" "${cc_launches[$((i-1))]:-true}"
    # Wait for npm update to settle before starting next column
    [[ $i -lt $num_projects ]] && sleep 2
  done

  # 最初の Claude ペインを選択
  local first_claude
  first_claude=$(tmux list-panes -t "$session:dev" -F '#{pane_id}:#{@role}' \
    | grep ':claude-p1$' | cut -d: -f1)
  [[ -n "$first_claude" ]] && tmux select-pane -t "$first_claude"
}

# === 単一プロジェクトモード（従来ロジック） ===

root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
name="$(basename "$root")"

# === セッション名決定 ===
if [[ "$WORKSPACE_MODE" == "true" ]]; then
  session="tproj-workspace"
else
  # リモート時はセッション名にホスト名を付加（ローカルと共存可能に）
  if [[ -n "$REMOTE_HOST" ]]; then
    safe_host="${REMOTE_HOST//\./-}"
    session="${name}@${safe_host}"
  else
    session="$name"
  fi
  # tmuxセッション名に使えない文字を潰す（@は許可）
  session="${session//[^A-Za-z0-9_@-]/_}"
fi

# === 同名セッションがあれば再作成 ===
echo "tproj: preparing session ${session}..." >&2
if tmux has-session -t "$session" 2>/dev/null; then
  # Collect descendant PIDs before killing (MCP servers etc.)
  local_desc=$(collect_session_descendants "$session") || true
  tmux kill-session -t "$session" 2>/dev/null || true
  kill_surviving_descendants "$local_desc"
fi

# Clean up orphaned MCP server processes from previous sessions
cleanup_orphaned_mcp

# === GUI アプリ即時起動（レイアウト構築と並行） ===
launch_tproj_gui

# === セッション作成 & ツール起動 ===
if [[ "$WORKSPACE_MODE" == "true" ]]; then
    # --- マルチプロジェクトモード ---
    echo "tproj: creating workspace layout..." >&2
    create_workspace_layout "$session" "${PROJECT_PATHS[@]}" -- "${PROJECT_TYPES[@]}" -- "${PROJECT_HOSTS[@]}" -- "${PROJECT_ALIASES[@]}"
    prime_after_layout_manifest "$session"
    start_workspace_tools "$session" "$NO_UPDATE" "${PROJECT_PATHS[@]}" -- "${PROJECT_TYPES[@]}" -- "${PROJECT_HOSTS[@]}" -- "${PROJECT_ALIASES[@]}" -- "${PROJECT_CC_LAUNCH[@]}" -- "${PROJECT_CDX_LAUNCH[@]}"

    # Background: prime personas then hot-swap titles + trigger background images
    prime_and_swap "$session" "workspace" "dev" &!

    tmux select-window -t "$session:dev"
  else
    # --- 単一プロジェクトモード ---
    # "プロジェクトのルート"を作業ディレクトリにする（gitならroot、無ければcwd）
    root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    echo "tproj: starting session for $(basename "$root")..." >&2

    # 1) dev window を作成
    tmux new-session -d -s "$session" -c "$root" -n dev
    mark_session_runtime "$session"

    # 2) VSCodeっぽい3ペイン（左メイン / 右上watch / 右下logs）
    tmux split-window -h -t "$session:dev" -c "$root"
    tmux split-window -v -t "$session:dev.2" -c "$root" -l 70%

    # split直後のPTYバッファ安定待ち（エスケープシーケンス漏れ防止）
    sleep 0.3

    # 3) ペインに @role タグを設定（Agent Teams 動的ペイン管理用）
    tmux set-option -pt "$session:dev.1" @role "claude"
    tmux set-option -pt "$session:dev.2" @role "codex"
    tmux set-option -pt "$session:dev.3" @role "yazi"
    tmux set-option -pt "$session:dev.1" @alias "$name"
    tmux set-option -pt "$session:dev.2" @alias "$name"
    tmux set-option -pt "$session:dev.3" @alias "$name"

    # Keep CC/Cdx panes alive if shell dies (watchdog will respawn)
    tmux set-option -pt "$session:dev.1" remain-on-exit on 2>/dev/null || true
    tmux set-option -pt "$session:dev.2" remain-on-exit on 2>/dev/null || true

    # 3.1) ペインタイトル設定（Claude/Codexのみ）
    title_host="local"
    [[ -n "$REMOTE_HOST" ]] && title_host="$REMOTE_HOST"
    claude_title=""
    codex_title=""
    claude_title="$(build_pane_label "${REMOTE_HOST:+remote}" "$title_host" "$root" "CC" "$name")"
    codex_title="$(build_pane_label "${REMOTE_HOST:+remote}" "$title_host" "$root" "Codex" "$name")"
    # CC/Codex の OSC タイトル上書きを抑止
    tmux set-option -pt "$session:dev.1" allow-set-title off 2>/dev/null || true
    tmux set-option -pt "$session:dev.2" allow-set-title off 2>/dev/null || true
    tmux select-pane -t "$session:dev.1" -T "$claude_title" 2>/dev/null || true
    tmux select-pane -t "$session:dev.2" -T "$codex_title" 2>/dev/null || true

    # 4) git window（差分やログ用）
    tmux new-window -t "$session" -n git -c "$root"
    apply_tmux_ui_to_window "$session:dev"
    apply_tmux_ui_to_window "$session:git"
    install_pane_focus_hook "$session"

    prime_after_layout_manifest "$session"

    # 5) コマンドを自動起動（リモート/ローカルで分岐）
    if [[ -n "$REMOTE_HOST" ]]; then
      # --- リモートモード: 先にSSHシェルを起動し、ツールは後から送信 ---
      # SSHでリモートのログインシェルに入る（ツール終了後もシェルが残る）
      for pane in 1 2 3; do
        tmux send-keys -t "$session:dev.$pane" \
          "ssh -t $REMOTE_HOST 'cd $root && exec \$SHELL -l'" C-m
      done
      tmux send-keys -t "$session:git" \
        "ssh -t $REMOTE_HOST 'cd $root && exec \$SHELL -l'" C-m

      # SSH接続待ち
      sleep 2

      # リモートシェル内でツールを起動
      claude_cmd="$(build_claude_launch_shell "$root" "remote" "false")"
      codex_cmd="$(build_codex_launch_shell "$root" "remote" "false")"
      tmux send-keys -t "$session:dev.1" "$(with_claude_update_prefix "$claude_cmd")" C-m
      sleep 0.1
      tmux send-keys -t "$session:dev.2" "$(with_codex_update_prefix "$codex_cmd")" C-m

      # Save launch commands for watchdog auto-restart
      tmux set-option -pt "$session:dev.1" @launch_cmd "$claude_cmd" 2>/dev/null || true
      tmux set-option -pt "$session:dev.2" @launch_cmd "$codex_cmd" 2>/dev/null || true

      sleep 0.3
      tmux send-keys -t "$session:dev.3" "yazi" C-m
    else
      # --- ローカルモード ---
      claude_cmd="$(build_claude_launch_shell "$root" "local" "false")"
      codex_cmd="$(build_codex_launch_shell "$root" "local" "false")"
      tmux send-keys -t "$session:dev.1" "$(with_claude_update_prefix "$claude_cmd")" C-m
      sleep 0.1
      tmux send-keys -t "$session:dev.2" "$(with_codex_update_prefix "$codex_cmd")" C-m

      # Save launch commands for watchdog auto-restart
      tmux set-option -pt "$session:dev.1" @launch_cmd "$claude_cmd" 2>/dev/null || true
      tmux set-option -pt "$session:dev.2" @launch_cmd "$codex_cmd" 2>/dev/null || true

      sleep 0.3
      tmux send-keys -t "$session:dev.3" "yazi" C-m

      tmux send-keys -t "$session:git" "echo '🌿 git (status/diff/log)'" C-m
    fi

    tmux select-window -t "$session:dev"
    tmux select-pane -t "$session:dev.1"

    # Background: prime personas then hot-swap titles + trigger background images
    prime_and_swap "$session" "single" "dev" "$root" "$REMOTE_HOST" &!
fi

# Pane auto-restart is handled by pane-died hook + tproj-respawn-guard (circuit breaker).
# Legacy tproj-pane-watchdog is disabled (requires bash 4+ declare -A, macOS ships bash 3.2).

echo "tproj: ready." >&2
exec tmux attach -t "$session"
