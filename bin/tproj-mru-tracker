#!/bin/bash
set -euo pipefail

SESSION="${1:-}"
PANE_ID="${2:-}"
WORKSPACE="${TPROJ_WORKSPACE_YAML:-$HOME/.config/tproj/workspace.yaml}"
STATE_DIR="${TPROJ_STATE_DIR:-$HOME/.config/tproj}"
THROTTLE_DIR="$STATE_DIR/mru-throttle"

[ -n "$SESSION" ] || exit 0
[ -n "$PANE_ID" ] || exit 0
[ -f "$WORKSPACE" ] || exit 0

PROJECT="$(tmux display-message -t "$PANE_ID" -p '#{@project}' 2>/dev/null || true)"
[ -n "$PROJECT" ] || exit 0

NOW="$(date +%s)"
KEY="$(printf '%s' "$PROJECT" | shasum | awk '{print $1}')"
mkdir -p "$THROTTLE_DIR" 2>/dev/null || true
STAMP_FILE="$THROTTLE_DIR/$KEY"

if [ -f "$STAMP_FILE" ]; then
  LAST="$(cat "$STAMP_FILE" 2>/dev/null || echo 0)"
  case "$LAST" in
    ''|*[!0-9]*) LAST=0 ;;
  esac
  if [ $((NOW - LAST)) -lt 2 ]; then
    exit 0
  fi
fi

TMP="$(mktemp "${WORKSPACE}.mru.XXXXXX")"
cleanup() {
  rm -f "$TMP"
}
trap cleanup EXIT

if TPROJ_MRU_PROJECT="$PROJECT" TPROJ_MRU_NOW="$NOW" \
  yq eval '(.projects[] | select(.path == strenv(TPROJ_MRU_PROJECT)).lastActiveAt) = (strenv(TPROJ_MRU_NOW) | tonumber)' "$WORKSPACE" > "$TMP"; then
  mv "$TMP" "$WORKSPACE"
  trap - EXIT
  printf '%s\n' "$NOW" > "$STAMP_FILE" 2>/dev/null || true
fi
